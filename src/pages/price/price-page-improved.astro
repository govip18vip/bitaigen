// src/pages/price/index-improved.astro
// 改进的行情总览页面 - 支持多语言 + 完整币种列表

---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import BinanceBanner from "@/components/BinanceBanner.astro";
import { SITE } from "@/config";
import { getLang, useTranslations, type Lang } from "@/i18n/ui";
import { MAJOR_COINS } from "@/utils/priceService";

const lang = getLang(Astro.url) as Lang;
const t = useTranslations(lang);

const coinEmojis: Record<string, string> = {
  bitcoin: "₿",
  ethereum: "⟠",
  binancecoin: "🔶",
  solana: "◎",
  ripple: "✕",
  cardano: "◆",
  dogecoin: "🐕",
  tron: "♦",
  polkadot: "●",
  litecoin: "Ł",
  "bitcoin-cash": "¤",
  chainlink: "🔗",
  uniswap: "◾",
  "wrapped-bitcoin": "₿",
  stellar: "★",
  cosmos: "⊕",
  "avalanche-2": "▲",
  polygon: "▮",
  arbitrum: "⬇",
  optimism: "⬆",
};

const pricePageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: lang === "zh-CN" 
    ? "加密货币实时行情 — BTC、ETH、BNB价格" 
    : "Cryptocurrency Live Prices - BTC, ETH, BNB",
  description: lang === "zh-CN"
    ? "实时追踪比特币、以太坊等主流加密货币价格，查看24小时涨跌幅和历史走势图。"
    : "Real-time tracking of Bitcoin, Ethereum and major cryptocurrencies with 24h price changes.",
  url: `${SITE.website}price`,
};

const siteUrl = SITE.website.replace(/\/$/, "");
---

<Layout
  title={lang === "zh-CN" 
    ? "加密货币实时行情 — BTC、ETH今日价格 | CryptoNews"
    : "Cryptocurrency Live Prices - BTC, ETH, Today | CryptoNews"}
  description={lang === "zh-CN"
    ? "实时追踪比特币BTC、以太坊ETH等主流加密货币价格，24小时涨跌幅、市值排行。"
    : "Real-time cryptocurrency prices for Bitcoin, Ethereum and major coins with 24h changes and market cap rankings."}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(pricePageSchema)} />
    <link rel="preconnect" href="https://api.coingecko.com" />
  </Fragment>

  <Header />
  <div class="site-outer">
    <LeftSidebar />
    <main class="main-col" id="main-content">

      <div style="padding:14px 16px 0;">
        <h1 style="font-size:20px;font-weight:800;color:var(--fg);margin:0 0 4px;">
          {lang === "zh-CN" ? "加密货币实时行情" : "Live Cryptocurrency Prices"}
        </h1>
        <p style="font-size:13px;color:var(--fg-muted);margin:0;">
          {lang === "zh-CN" 
            ? "实时价格 · 数据来源 CoinGecko · 每60秒更新"
            : "Live prices · Data from CoinGecko · Updates every 60s"}
        </p>
      </div>

      <!-- 价格表格 -->
      <section style="padding:12px 16px 0;">
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:8px;overflow:hidden;">
          <!-- 表头 -->
          <div style="display:grid;grid-template-columns:2fr 1fr 1fr 1fr 1fr;gap:0;padding:10px 16px;background:var(--bg-elevated);border-bottom:1px solid var(--border);font-size:11px;font-weight:700;color:var(--fg-muted);text-transform:uppercase;letter-spacing:0.05em;">
            <span>{lang === "zh-CN" ? "币种" : "Coin"}</span>
            <span style="text-align:right;">{lang === "zh-CN" ? "价格 (USD)" : "Price (USD)"}</span>
            <span style="text-align:right;"{lang === "zh-CN" ? "24h" : "24h"}涨跌</span>
            <span style="text-align:right;">{lang === "zh-CN" ? "市值" : "Market Cap"}</span>
            <span style="text-align:right;">{lang === "zh-CN" ? "排名" : "Rank"}</span>
          </div>
          
          <!-- 币种列表 -->
          <div id="price-table">
            {MAJOR_COINS.map((coin, i) => (
              <a href={`/coin/${coin.symbol.toLowerCase()}`}
                style={`display:grid;grid-template-columns:2fr 1fr 1fr 1fr 1fr;gap:0;padding:12px 16px;border-bottom:${i < MAJOR_COINS.length - 1 ? "1px solid var(--border-subtle)" : "none"};text-decoration:none;color:var(--fg);transition:background 0.12s;align-items:center;`}
                onmouseover="this.style.background='var(--bg-elevated)'"
                onmouseout="this.style.background='transparent'"
                data-coin={coin.id}
              >
                <!-- 币种名称 -->
                <div style="display:flex;align-items:center;gap:10px;min-width:0;">
                  <div style="width:32px;height:32px;border-radius:50%;background:var(--bg-elevated);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;border:1px solid var(--border);">
                    {coinEmojis[coin.id] || "₿"}
                  </div>
                  <div style="min-width:0;">
                    <div style="font-size:13px;font-weight:600;color:var(--fg);">{coin.name}</div>
                    <div style="font-size:11px;color:var(--fg-muted);">{coin.symbol}</div>
                  </div>
                </div>
                
                <!-- 价格 -->
                <div id={`p-${coin.id}`} style="text-align:right;font-size:13px;font-weight:700;color:var(--fg);font-variant-numeric:tabular-nums;">—</div>
                
                <!-- 24h涨跌 -->
                <div id={`c-${coin.id}`} style="text-align:right;font-size:12px;font-weight:600;">—</div>
                
                <!-- 市值 -->
                <div id={`m-${coin.id}`} style="text-align:right;font-size:12px;color:var(--fg-muted);">—</div>
                
                <!-- 排名 -->
                <div id={`r-${coin.id}`} style="text-align:right;font-size:12px;font-weight:600;color:var(--accent);">—</div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- 币安购买 -->
      <div style="padding:0 16px;">
        <BinanceBanner variant="hero" lang={lang} />
      </div>

      <!-- 详情页链接 -->
      <section style="padding:0 16px 20px;">
        <div class="sec-head" style="padding-left:0;margin-bottom:12px;">
          <span class="sec-head-title">
            {lang === "zh-CN" ? "热门币种详情" : "Popular Coins"}
          </span>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
          {MAJOR_COINS.slice(0, 4).map(coin => (
            <a href={`/coin/${coin.symbol.toLowerCase()}`}
              style="display:flex;align-items:center;gap:12px;padding:12px;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;text-decoration:none;transition:border-color 0.12s;"
              onmouseover="this.style.borderColor='var(--accent)'" 
              onmouseout="this.style.borderColor='var(--border)'">
              <div style="width:40px;height:40px;border-radius:50%;background:var(--bg-elevated);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;border:1px solid var(--border);">
                {coinEmojis[coin.id] || "₿"}
              </div>
              <div style="min-width:0;">
                <div style="font-size:13px;font-weight:700;color:var(--fg);">{coin.symbol}</div>
                <div style="font-size:11px;color:var(--fg-muted);">
                  {lang === "zh-CN" ? "查看详情" : "Details"}
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>

    </main>

    <!-- 右侧栏 -->
    <aside class="rsidebar" style="padding:16px 0;">
      <div class="rsidebar-section">
        <BinanceBanner variant="compact" lang={lang} />
      </div>
    </aside>
  </div>
  <Footer />
</Layout>

<script is:inline>
(async function(){
  const fmt = n => {
    if(!n) return "$0";
    if(n >= 1e9) return "$"+(n/1e9).toFixed(2)+"B";
    if(n >= 1e6) return "$"+(n/1e6).toFixed(0)+"M";
    return "$"+n.toLocaleString("en-US",{maximumFractionDigits:0});
  };
  const fmtP = n => n >= 1000 ? "$"+n.toLocaleString("en-US",{maximumFractionDigits:0}) : "$"+n.toFixed(3);

  async function updatePrices(){
    try {
      const r = await fetch("/api/prices.json", {signal:AbortSignal.timeout(10000)});
      if(!r.ok) return;
      const data = await r.json();
      
      for(const [id, coin] of Object.entries(data.data)){
        const pe = document.getElementById("p-"+id);
        const ce = document.getElementById("c-"+id);
        const me = document.getElementById("m-"+id);
        const re = document.getElementById("r-"+id);
        
        if(pe && coin.priceUSD) pe.textContent = fmtP(coin.priceUSD);
        
        if(ce && coin.change24h !== null){
          const chg = coin.change24h;
          ce.textContent = (chg >= 0 ? "▲ +" : "▼ ") + chg.toFixed(2) + "%";
          ce.style.color = chg >= 0 ? "var(--accent-green)" : "var(--accent-red)";
        }
        
        if(me && coin.marketCap) me.textContent = fmt(coin.marketCap);
        if(re && coin.rank) re.textContent = "#"+coin.rank;
      }
    } catch(e){}
  }
  
  updatePrices();
  setInterval(updatePrices, 60000);
})();
</script>

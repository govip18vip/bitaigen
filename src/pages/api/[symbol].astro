// src/pages/coin/[symbol].astro
// 单个币种详情页面 — 包含行情、信息、新闻

---
import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import BinanceBanner from "@/components/BinanceBanner.astro";
import { MAJOR_COINS, priceService } from "@/utils/priceService";
import { getCoinInfo } from "@/utils/coinInfo";
import { getLang, useTranslations, type Lang } from "@/i18n/ui";
import { getPath } from "@/utils/getPath";

export const getStaticPaths = (async () => {
  return MAJOR_COINS.map(coin => ({
    params: { symbol: coin.symbol.toLowerCase() },
    props: { coinId: coin.id, coinSymbol: coin.symbol },
  }));
}) satisfies GetStaticPaths;

const { coinId, coinSymbol } = Astro.props;
const lang = getLang(Astro.url) as Lang;
const t = useTranslations(lang);

// 获取币种信息
const coinInfo = getCoinInfo(coinId, lang);

// 获取价格数据
const prices = await priceService.getMultiplePrices([coinId]);
const priceData = prices[coinId];

// 获取相关资讯
const allPosts = await getCollection("blog");
const relatedPosts = allPosts
  .filter(p => {
    const tags = (p.data.tags || []).map(t => t.toLowerCase());
    return tags.includes(coinSymbol.toLowerCase()) ||
           tags.includes(coinId.toLowerCase());
  })
  .sort((a, b) => 
    new Date(b.data.pubDatetime).getTime() - new Date(a.data.pubDatetime).getTime()
  )
  .slice(0, 8);

const pageTitle = `${coinSymbol} - ${coinInfo?.name[lang] || coinId} | ${t("site.name")}`;
const description = coinInfo?.description[lang] || `${coinSymbol} 实时价格、行情分析和资讯`;

// 价格格式化
const fmt = (n: number) => {
  if (!n) return "$0";
  if (n >= 1e9) return "$" + (n / 1e9).toFixed(2) + "B";
  if (n >= 1e6) return "$" + (n / 1e6).toFixed(0) + "M";
  return "$" + n.toLocaleString("en-US", { maximumFractionDigits: 0 });
};

const fmtPrice = (n: number) => {
  if (!n) return "$0";
  if (n >= 1000) return "$" + n.toLocaleString("en-US", { maximumFractionDigits: 0 });
  return "$" + n.toFixed(2);
};
---

<Layout title={pageTitle} description={description}>
  <Header />

  <div class="site-outer">
    <LeftSidebar />

    <main class="main-col" id="main-content">

      <!-- 币种 Hero 卡片 -->
      <section style="padding:16px;">
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:8px;overflow:hidden;">
          <!-- 顶部信息 -->
          <div style="display:flex;align-items:center;gap:14px;padding:20px 24px;border-bottom:1px solid var(--border);">
            <div style="width:48px;height:48px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:900;color:#fff;flex-shrink:0;">
              {coinSymbol.slice(0, 1)}
            </div>
            <div style="flex:1;">
              <div style="font-size:20px;font-weight:800;color:var(--fg);">{coinInfo?.name[lang] || coinId}</div>
              <div style="font-size:13px;color:var(--fg-muted);">{coinSymbol}</div>
            </div>
            <div style="display:flex;gap:8px;">
              <span class="ctag">{priceData?.rank || '—'}位</span>
              <span class="ctag-blue">市值排行</span>
            </div>
          </div>

          <!-- 价格数据 -->
          <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:0;border-bottom:1px solid var(--border);">
            <div style="padding:16px 20px;border-right:1px solid var(--border);">
              <div style="font-size:11px;color:var(--fg-muted);margin-bottom:6px;">价格 (USD)</div>
              <div style="font-size:28px;font-weight:800;color:var(--fg);font-variant-numeric:tabular-nums;">
                {priceData ? fmtPrice(priceData.priceUSD) : '—'}
              </div>
              <div style={`font-size:13px;margin-top:4px;font-weight:600;color:${priceData && priceData.change24h >= 0 ? 'var(--accent-green)' : 'var(--accent-red)'}`}>
                {priceData ? `${priceData.change24h >= 0 ? '▲ +' : '▼ '}${Math.abs(priceData.change24h).toFixed(2)}%` : '—'}
              </div>
            </div>
            <div style="padding:16px 20px;border-right:1px solid var(--border);">
              <div style="font-size:11px;color:var(--fg-muted);margin-bottom:6px;">24h 最高/最低</div>
              <div style="font-size:14px;font-weight:700;color:var(--fg);">{priceData ? fmtPrice(priceData.high24h) : '—'}</div>
              <div style="font-size:13px;font-weight:600;color:var(--fg);margin-top:3px;">{priceData ? fmtPrice(priceData.low24h) : '—'}</div>
            </div>
            <div style="padding:16px 20px;border-right:1px solid var(--border);">
              <div style="font-size:11px;color:var(--fg-muted);margin-bottom:6px;">市值 / 24h成交量</div>
              <div style="font-size:14px;font-weight:700;color:var(--fg);">{priceData ? fmt(priceData.marketCap) : '—'}</div>
              <div style="font-size:13px;font-weight:600;color:var(--fg);margin-top:3px;">{priceData ? fmt(priceData.volume24h) : '—'}</div>
            </div>
            <div style="padding:16px 20px;">
              <div style="font-size:11px;color:var(--fg-muted);margin-bottom:6px;">流通量 / 总供应</div>
              <div style="font-size:13px;font-weight:700;color:var(--fg);">{priceData ? `${(priceData.circulatingSupply / 1e6).toFixed(1)}M` : '—'}</div>
              <div style="font-size:13px;font-weight:600;color:var(--fg);margin-top:3px;">{priceData ? `${(priceData.totalSupply / 1e6).toFixed(1)}M` : '—'}</div>
            </div>
          </div>

          <!-- 更新时间 -->
          <div style="padding:12px 24px;font-size:11px;color:var(--fg-light);">
            最后更新：<span id={`updated-${coinId}`}>—</span> · 每60秒自动刷新
          </div>
        </div>
      </section>

      <!-- 币种信息 -->
      {coinInfo && (
        <section style="padding:0 16px 16px;">
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:8px;padding:20px 24px;">
            <h2 style="font-size:16px;font-weight:700;color:var(--fg);margin:0 0 16px;display:flex;align-items:center;gap:8px;">
              <span style="width:3px;height:18px;background:var(--accent);border-radius:2px;display:inline-block;"></span>
              项目信息 / Project Info
            </h2>
            
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px;">
              {[
                ["描述 / Description", coinInfo.description[lang]],
                ["使用场景 / Use Case", coinInfo.useCase[lang]],
                ["共识机制 / Consensus", coinInfo.consensus || "—"],
                ["区块时间 / Block Time", coinInfo.blockTime || "—"],
                ["最大供应 / Max Supply", coinInfo.maxSupply || "无限 / Unlimited"],
                ["创始人 / Founder", coinInfo.founder || "—"],
                ["推出日期 / Launch Date", coinInfo.launchDate || "—"],
              ].map(([label, value]) => (
                <div style="border-bottom:1px solid var(--border-subtle);padding:8px 0;">
                  <div style="font-size:12px;color:var(--fg-muted);margin-bottom:3px;">{label}</div>
                  <div style="font-size:13px;color:var(--fg);font-weight:500;line-height:1.5;">{value}</div>
                </div>
              ))}
            </div>

            <!-- 官方链接 -->
            <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:16px;padding-top:16px;border-top:1px solid var(--border);">
              {coinInfo.officialWebsite && (
                <a href={coinInfo.officialWebsite} target="_blank" rel="noopener noreferrer"
                  style="display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:5px;background:var(--tag-orange-bg);color:var(--accent);text-decoration:none;font-size:12px;font-weight:600;transition:all 0.12s;"
                  onmouseover="this.style.background='rgba(247,147,26,0.2)'" onmouseout="this.style.background='var(--tag-orange-bg)'">
                  🌐 官网 / Website
                </a>
              )}
              {coinInfo.whitepaper && (
                <a href={coinInfo.whitepaper} target="_blank" rel="noopener noreferrer"
                  style="display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:5px;background:var(--tag-blue-bg);color:var(--accent-blue);text-decoration:none;font-size:12px;font-weight:600;">
                  📄 白皮书 / Whitepaper
                </a>
              )}
              {coinInfo.blockExplorer && (
                <a href={coinInfo.blockExplorer} target="_blank" rel="noopener noreferrer"
                  style="display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:5px;background:var(--tag-green-bg);color:var(--accent-green);text-decoration:none;font-size:12px;font-weight:600;">
                  🔍 区块浏览器 / Explorer
                </a>
              )}
              {coinInfo.twitter && (
                <a href={coinInfo.twitter} target="_blank" rel="noopener noreferrer"
                  style="display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:5px;background:rgba(29,155,240,.15);color:#1d9bf0;text-decoration:none;font-size:12px;font-weight:600;">
                  𝕏 Twitter
                </a>
              )}
              {coinInfo.telegram && (
                <a href={coinInfo.telegram} target="_blank" rel="noopener noreferrer"
                  style="display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:5px;background:rgba(0,136,204,.15);color:#0088cc;text-decoration:none;font-size:12px;font-weight:600;">
                  ✈️ Telegram
                </a>
              )}
            </div>
          </div>
        </section>
      )}

      <!-- 币安购买 -->
      <div style="padding:0 16px;">
        <BinanceBanner variant="article" lang={lang} />
      </div>

      <!-- 相关资讯 -->
      {relatedPosts.length > 0 && (
        <section style="padding:0 16px 20px;">
          <div style="display:flex;align-items:center;justify-content:space-between;padding:0 0 10px;margin-bottom:12px;">
            <div style="font-size:16px;font-weight:700;color:var(--fg);display:flex;align-items:center;gap:8px;">
              <span style="width:3px;height:18px;background:var(--accent);border-radius:2px;display:inline-block;"></span>
              相关资讯 / Related News
            </div>
            <a href={`/tags/${coinSymbol.toLowerCase()}`} style="font-size:12.5px;color:var(--fg-muted);text-decoration:none;">
              查看全部 →
            </a>
          </div>
          <div style="background:var(--bg-card);margin:0;border-radius:6px;border:1px solid var(--border);overflow:hidden;">
            {relatedPosts.map((post, i) => (
              <a href={getPath(post.id, post.filePath)}
                style={`display:flex;gap:12px;padding:12px 16px;text-decoration:none;color:var(--fg);transition:background 0.12s;${i < relatedPosts.length - 1 ? 'border-bottom:1px solid var(--border-subtle);' : ''}`}
                onmouseover="this.style.background='var(--bg-elevated)'" onmouseout="this.style.background='transparent'">
                <div style="flex:1;min-width:0;">
                  <div style="font-size:13px;font-weight:600;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                    {post.data.title}
                  </div>
                  <div style="font-size:11px;color:var(--fg-light);margin-top:4px;">
                    {new Date(post.data.pubDatetime).toLocaleDateString(lang === 'zh-CN' ? 'zh-CN' : 'en-US')}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

    </main>

    <!-- 右侧栏 -->
    <aside class="rsidebar" style="padding:16px 0;">
      <div class="rsidebar-section">
        <div class="rsidebar-head">⚡ 快速操作</div>
        <a href={`https://www.binance.com/en/register?ref=B2345`} target="_blank" rel="noopener noreferrer sponsored"
          style="display:block;padding:10px;background:var(--accent);color:#fff;border-radius:5px;text-decoration:none;font-size:13px;font-weight:700;text-align:center;margin-bottom:8px;transition:opacity 0.12s;"
          onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
          在币安购买 {coinSymbol}
        </a>
        <p style="font-size:10px;color:var(--fg-muted);text-align:center;margin:0;">邀请码 B2345 · 最高折扣</p>
      </div>

      <div class="rsidebar-section">
        <BinanceBanner variant="compact" lang={lang} />
      </div>
    </aside>
  </div>

  <Footer />
</Layout>

<script is:inline define:vars={{coinId}}>
// 自动刷新价格数据
(function(){
  async function updatePrice(){
    try {
      const r = await fetch(`/api/prices.json?ids=${coinId}`, {
        signal: AbortSignal.timeout(8000)
      });
      if(!r.ok) return;
      const data = await r.json();
      if(!data.data[coinId]) return;
      
      const coin = data.data[coinId];
      document.getElementById(`updated-${coinId}`).textContent = 
        new Date().toLocaleTimeString('zh-CN', {hour:'2-digit',minute:'2-digit'});
    } catch(e){}
  }
  
  updatePrice();
  setInterval(updatePrice, 60000);
})();
</script>

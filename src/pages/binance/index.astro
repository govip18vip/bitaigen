---
// src/pages/binance/index.astro
// 币安专题 Pillar Page — /binance
// 汇总 12 个子话题，内链+CTA 兼顾 SEO 与转化

import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
import {
  BINANCE_SECTIONS,
  BINANCE_REG_URL,
  BINANCE_DL_APK,
  BINANCE_REF,
  DIFFICULTY_LABEL,
} from "@/data/binance-sections";
import { binancePillarHreflang } from "@/data/binance-i18n";

const hreflangLinks = binancePillarHreflang(SITE.website);

const REF   = BINANCE_REF;
const APK   = BINANCE_DL_APK;
const WEB   = BINANCE_REG_URL;
const LOGO  = "https://basebiance.com/content/images/2025/04/1HH5201407.png";

// ── Schema ───────────────────────────────────────────────────
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "币安Binance完全使用指南2026 — 注册下载到进阶交易",
  description: "币安(Binance)完整使用教程，涵盖注册、下载、KYC认证、充提币、现货期货交易、P2P、安全设置等12大专题，使用邀请码B2345享最高折扣。",
  url: `${SITE.website}binance`,
  breadcrumb: {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "首页", item: SITE.website },
      { "@type": "ListItem", position: 2, name: "币安教程", item: `${SITE.website}binance` },
    ],
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "币安邀请码B2345有什么优惠？",
      acceptedAnswer: { "@type": "Answer",
        text: "使用邀请码B2345注册币安，可享受平台最高可用的手续费折扣，现货交易手续费最低可至0.075%，长期交易可节省大量成本。" },
    },
    {
      "@type": "Question",
      name: "国内如何下载币安APP？",
      acceptedAnswer: { "@type": "Answer",
        text: "安卓用户可直接下载APK安装包，无需应用商店，国内网络可访问。iOS用户需要海外Apple ID登录App Store搜索Binance下载。" },
    },
    {
      "@type": "Question",
      name: "币安KYC认证需要多久？",
      acceptedAnswer: { "@type": "Answer",
        text: "通常5到30分钟完成，高峰期可能延长至24小时。提交身份证正反面和人脸识别照片后系统自动审核。" },
    },
    {
      "@type": "Question",
      name: "币安手续费怎么计算？",
      acceptedAnswer: { "@type": "Answer",
        text: "现货标准手续费0.1%，使用邀请码B2345可享折扣。用BNB支付手续费额外再享25%折扣。VIP用户根据交易量享受更低费率。" },
    },
  ],
};
---

<Layout
  title="币安完全使用指南2026 — 12大专题教程 | Bitaigen"
  description="币安Binance完整教程：注册、APP下载、KYC认证、充值提币、现货期货、P2P交易、手续费、安全设置等12个专题，使用邀请码B2345享手续费折扣。"
  keywords="币安教程,binance使用指南,币安注册,binance下载,币安KYC,币安手续费,币安安全设置"
  canonicalURL={`${SITE.website}binance`}
>
  <Fragment slot="head">
    {hreflangLinks.map(l => (
      <link rel="alternate" hreflang={l.lang} href={l.href} />
    ))}
    <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Header />

  <main id="main-content" style="max-width:860px;margin:0 auto;padding:0 16px 80px;">

    <!-- ══ HERO ══ -->
    <section style="text-align:center;padding:44px 0 36px;">
      <div style="display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:18px;">
        <img src={LOGO} alt="币安 Binance Logo" width="44" height="44"
          style="border-radius:10px;flex-shrink:0;" loading="eager" />
        <span style="font-size:28px;font-weight:900;color:var(--fg);letter-spacing:-0.02em;">Binance 币安</span>
      </div>
      <h1 style="font-size:clamp(22px,4vw,36px);font-weight:900;color:var(--fg);line-height:1.2;margin:0 0 14px;letter-spacing:-0.02em;">
        币安完全使用指南 2026
      </h1>
      <p style="font-size:16px;color:var(--fg-muted);line-height:1.7;margin:0 auto 28px;max-width:580px;">
        从注册到进阶交易，12 大专题全覆盖。使用邀请码&nbsp;
        <strong style="color:#F0B90B;font-family:monospace;font-size:18px;">{REF}</strong>
        &nbsp;注册，享平台最高手续费折扣。
      </p>

      <!-- CTA 按钮组 -->
      <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:center;max-width:500px;margin:0 auto 10px;">
        <a href={APK} target="_blank" rel="noopener noreferrer nofollow sponsored"
          style="flex:1;min-width:160px;display:flex;align-items:center;justify-content:center;gap:8px;padding:14px 22px;background:#F0B90B;color:#1a1200;border-radius:10px;text-decoration:none;font-weight:800;font-size:15px;box-shadow:0 4px 14px rgba(240,185,11,0.35);transition:all 0.12s;"
          onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform=''"
        >
          📱 大陆版APK下载
        </a>
        <a href={WEB} target="_blank" rel="noopener noreferrer nofollow sponsored"
          style="flex:1;min-width:160px;display:flex;align-items:center;justify-content:center;gap:8px;padding:14px 22px;background:var(--bg-card);color:var(--fg);border:2px solid #F0B90B;border-radius:10px;text-decoration:none;font-weight:700;font-size:15px;transition:all 0.12s;"
          onmouseover="this.style.background='rgba(240,185,11,0.1)'" onmouseout="this.style.background='var(--bg-card)'"
        >
          🌐 网页版注册
        </a>
      </div>
      <p style="font-size:11px;color:var(--fg-light);margin:8px 0 0;">
        ⚠️ 投资有风险，加密货币价格波动较大，请谨慎决策。本站与币安存在联盟合作关系。
      </p>
    </section>

    <!-- ══ 邀请码展示条 ══ -->
    <div style="display:flex;align-items:center;justify-content:center;gap:14px;background:rgba(240,185,11,0.08);border:1.5px dashed rgba(240,185,11,0.45);border-radius:10px;padding:14px 24px;margin-bottom:36px;flex-wrap:wrap;">
      <span style="font-size:13px;color:var(--fg-muted);">专属邀请码</span>
      <span style="font-size:28px;font-weight:900;color:#F0B90B;font-family:monospace;letter-spacing:0.12em;">{REF}</span>
      <button
        onclick={`navigator.clipboard.writeText('${REF}').then(()=>{this.textContent='已复制✓';setTimeout(()=>this.textContent='复制',1500)})`}
        style="padding:6px 16px;background:rgba(240,185,11,0.2);border:1px solid rgba(240,185,11,0.4);border-radius:6px;font-size:12px;color:#F0B90B;cursor:pointer;font-weight:700;transition:all 0.12s;"
      >复制</button>
      <span style="font-size:12px;color:var(--fg-muted);">现货折扣 · 注册即享</span>
    </div>

    <!-- ══ 12 大专题卡片 ══ -->
    <section style="margin-bottom:48px;">
      <h2 style="font-size:20px;font-weight:800;color:var(--fg);margin:0 0 20px;display:flex;align-items:center;gap:8px;">
        <span style="width:4px;height:22px;background:#F0B90B;border-radius:2px;display:inline-block;"></span>
        12 大专题教程
      </h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:14px;">
        {BINANCE_SECTIONS.map(section => (
          <a
            href={`/binance/${section.id}`}
            style="display:flex;flex-direction:column;gap:10px;padding:20px;background:var(--bg-card);border:1px solid var(--border);border-radius:12px;text-decoration:none;transition:all 0.15s;group"
            onmouseover="this.style.borderColor='#F0B90B';this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 16px rgba(240,185,11,0.12)'"
            onmouseout="this.style.borderColor='var(--border)';this.style.transform='';this.style.boxShadow=''"
          >
            <div style="display:flex;align-items:center;gap:10px;">
              <span style="font-size:24px;line-height:1;">{section.icon}</span>
              <div>
                <div style="font-size:15px;font-weight:700;color:var(--fg);line-height:1.3;">{section.shortTitle}</div>
                <div style="font-size:11px;color:var(--fg-muted);margin-top:2px;">
                  {DIFFICULTY_LABEL[section.difficulty]} · ⏱ {section.estimatedTime}
                </div>
              </div>
            </div>
            <p style="font-size:12.5px;color:var(--fg-muted);line-height:1.6;margin:0;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
              {section.intro}
            </p>
            <span style="font-size:12px;color:#F0B90B;font-weight:600;display:flex;align-items:center;gap:4px;">
              查看教程
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- ══ 为什么选择币安 ══ -->
    <section style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:32px;margin-bottom:32px;">
      <h2 style="font-size:18px;font-weight:800;color:var(--fg);margin:0 0 22px;display:flex;align-items:center;gap:8px;">
        <span style="width:4px;height:22px;background:#F0B90B;border-radius:2px;display:inline-block;"></span>
        为什么选择币安？
      </h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;">
        {[
          { icon: "🏆", title: "全球第一交易所", desc: "日均交易量超700亿美元，流动性全球最强" },
          { icon: "💰", title: "最低手续费", desc: "邀请码B2345可享最高折扣，最低0.075%" },
          { icon: "🔒", title: "SAFU安全基金", desc: "10亿美元专项储备保障用户资产安全" },
          { icon: "📊", title: "350+交易品种", desc: "主流币、DeFi、新币一站全覆盖" },
          { icon: "📱", title: "全中文支持", desc: "APP和网页均支持中文界面与中文客服" },
          { icon: "⚡", title: "多样化产品", desc: "现货、合约、P2P、赚币、NFT全都有" },
        ].map(item => (
          <div style="display:flex;gap:12px;align-items:flex-start;">
            <span style="font-size:22px;flex-shrink:0;line-height:1.2;">{item.icon}</span>
            <div>
              <div style="font-size:13px;font-weight:700;color:var(--fg);margin-bottom:3px;">{item.title}</div>
              <div style="font-size:12px;color:var(--fg-muted);line-height:1.5;">{item.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ══ 快速入门指引 ══ -->
    <section style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:32px;margin-bottom:32px;">
      <h2 style="font-size:18px;font-weight:800;color:var(--fg);margin:0 0 22px;display:flex;align-items:center;gap:8px;">
        <span style="width:4px;height:22px;background:#F0B90B;border-radius:2px;display:inline-block;"></span>
        新手快速入门路径
      </h2>
      <div style="display:flex;flex-direction:column;gap:0;">
        {[
          { step:"1", label:"注册账户", href:"/binance/register", desc:"3分钟完成，支持手机/邮箱注册，邀请码B2345自动填入" },
          { step:"2", label:"下载APP",  href:"/binance/download", desc:"安卓直接下载APK，iOS使用海外Apple ID" },
          { step:"3", label:"完成KYC",  href:"/binance/kyc",      desc:"提交身份证，解锁提币和全功能权限" },
          { step:"4", label:"充值入金",  href:"/binance/deposit",  desc:"支持USDT转账、银行卡、P2P多种方式" },
          { step:"5", label:"开始交易",  href:"/binance/spot",     desc:"从现货交易开始，界面简洁，新手友好" },
        ].map((item, i) => (
          <a
            href={item.href}
            style={`display:flex;gap:16px;align-items:flex-start;padding:14px 0;text-decoration:none;${i < 4 ? "border-bottom:1px solid var(--border-subtle);" : ""}`}
            onmouseover="this.querySelector('.step-title').style.color='#F0B90B'"
            onmouseout="this.querySelector('.step-title').style.color='var(--fg)'"
          >
            <div style="width:36px;height:36px;border-radius:50%;background:#F0B90B;color:#1a1200;font-size:15px;font-weight:900;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{item.step}</div>
            <div>
              <div class="step-title" style="font-size:14px;font-weight:700;color:var(--fg);margin-bottom:3px;transition:color 0.12s;">{item.label}</div>
              <div style="font-size:12.5px;color:var(--fg-muted);line-height:1.6;">{item.desc}</div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ══ FAQ ══ -->
    <section style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:32px;margin-bottom:32px;">
      <h2 style="font-size:18px;font-weight:800;color:var(--fg);margin:0 0 20px;display:flex;align-items:center;gap:8px;">
        <span style="width:4px;height:22px;background:#F0B90B;border-radius:2px;display:inline-block;"></span>
        常见问题
      </h2>
      <div style="display:flex;flex-direction:column;gap:10px;">
        {[
          ["邀请码B2345有什么优惠？","使用邀请码B2345注册币安，可享受平台最高可用的手续费折扣，现货交易手续费最低可至0.075%，长期交易可节省大量成本。"],
          ["国内如何下载币安APP？","安卓用户可直接点击上方「大陆版APK下载」按钮，无需应用商店，国内网络可正常下载安装。iOS用户需要海外Apple ID。"],
          ["币安KYC认证需要多久？","通常5到30分钟完成，高峰期可能延长至24小时。提交身份证正反面和人脸识别照片后系统自动审核。"],
          ["币安安全吗？怎么保证资产安全？","币安持有多国合规牌照，设有10亿美元SAFU安全基金。建议开启2FA双重认证、设置白名单地址、启用设备管理等安全功能。"],
          ["币安手续费怎么计算？","现货标准手续费0.1%，使用邀请码B2345享折扣，用BNB支付再享25%折扣。合约手续费根据VIP等级有所不同。"],
        ].map(([q, a]) => (
          <details style="background:var(--bg-elevated);border:1px solid var(--border);border-radius:8px;padding:14px 16px;cursor:pointer;">
            <summary style="font-size:14px;font-weight:600;color:var(--fg);list-style:none;display:flex;justify-content:space-between;align-items:center;gap:12px;">
              <span>{q}</span>
              <span style="color:#F0B90B;font-size:20px;flex-shrink:0;">+</span>
            </summary>
            <p style="font-size:13px;color:var(--fg-muted);line-height:1.7;margin:12px 0 0;">{a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- ══ 底部终极 CTA ══ -->
    <section style="background:linear-gradient(135deg,#1a1200,#2a1e00);border:1px solid rgba(240,185,11,0.3);border-radius:14px;padding:36px;text-align:center;">
      <img src={LOGO} alt="Binance" width="52" height="52" style="border-radius:12px;margin-bottom:16px;" />
      <h2 style="font-size:22px;font-weight:900;color:#F0B90B;margin:0 0 10px;">立即注册，终身享受折扣</h2>
      <p style="font-size:14px;color:rgba(255,255,255,0.65);margin:0 0 26px;line-height:1.7;">
        邀请码 <strong style="color:#F0B90B;font-family:monospace;font-size:18px;">{REF}</strong> — 注册即锁定最高折扣，永久有效
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:center;max-width:440px;margin:0 auto;">
        <a href={APK} target="_blank" rel="noopener noreferrer nofollow sponsored"
          style="flex:1;min-width:150px;display:flex;align-items:center;justify-content:center;gap:8px;padding:14px;background:#F0B90B;color:#1a1200;border-radius:10px;text-decoration:none;font-size:15px;font-weight:800;transition:all 0.12s;"
          onmouseover="this.style.background='#ffd700'" onmouseout="this.style.background='#F0B90B'"
        >
          📱 大陆版APK下载
        </a>
        <a href={WEB} target="_blank" rel="noopener noreferrer nofollow sponsored"
          style="flex:1;min-width:150px;display:flex;align-items:center;justify-content:center;gap:8px;padding:14px;background:transparent;color:rgba(255,255,255,0.8);border:1px solid rgba(255,255,255,0.25);border-radius:10px;text-decoration:none;font-size:14px;font-weight:600;transition:all 0.12s;"
          onmouseover="this.style.borderColor='rgba(255,255,255,0.5)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.25)'"
        >
          🌐 网页版注册
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

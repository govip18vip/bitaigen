---
// src/pages/[lang]/posts/[...page].astro
// 生成非默认语言的文章列表：/en/posts/  /zh-tw/posts/  等
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import { SITE } from "@/config";
import {
  LANGUAGES, DEFAULT_LANG, useTranslations,
  LANG_TO_PATH, type Lang,
} from "@/i18n/ui";
import { filterPostsByLang } from "@/utils/homePage";

export const getStaticPaths = (async ({ paginate }) => {
  const nonDefaultLangs = Object.keys(LANGUAGES)
    .filter(l => l !== DEFAULT_LANG) as Lang[];

  const allPosts = await getCollection("blog", ({ data }) => !data.draft);

  return nonDefaultLangs.flatMap(lang => {
    const langPosts = filterPostsByLang(allPosts, lang);
    return paginate(langPosts, {
      params: { lang },
      pageSize: SITE.postPerPage,
    });
  });
}) satisfies GetStaticPaths;

const { lang: langParam } = Astro.params;
const lang = langParam as Lang;
const t = useTranslations(lang);
const { page } = Astro.props;

const postsBase = `/${LANG_TO_PATH[lang]}/posts`;
---

<Layout title={`${t("section.all")} | ${t("site.name")}`} description={t("site.desc")}>
  <Header />

  <div class="site-outer">
    <LeftSidebar currentLang={lang} />

    <div class="main-col" style="padding-bottom:40px;">
      <!-- Breadcrumb -->
      <div style="padding:14px 16px 0;font-size:13px;color:var(--fg-muted);">
        <a href={`/${LANG_TO_PATH[lang]}/`}
          style="color:var(--fg-muted);text-decoration:none;"
          onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--fg-muted)'">
          {t("nav.home")}
        </a>
        <span style="margin:0 6px;">›</span>
        <span style="color:var(--fg);">{t("section.all")}</span>
      </div>

      <div style="padding:12px 16px 0;">
        <h1 style="font-size:20px;font-weight:700;color:var(--fg);margin-bottom:4px;">
          {t("section.all")}
        </h1>
        <p style="font-size:13px;color:var(--fg-muted);">
          {t("site.desc.short")}
        </p>
      </div>

      <!-- Articles -->
      <div style="margin-top:14px;">
        {page.data.length > 0 ? (
          <div class="alist">
            {page.data.map(data => <Card {...data} size="list" variant="h3" />)}
          </div>
        ) : (
          <div style="padding:60px 16px;text-align:center;color:var(--fg-muted);">
            <p style="font-size:16px;margin-bottom:8px;">📝 No articles yet</p>
            <p style="font-size:13px;opacity:0.7;">
              Add .md files to <code>src/data/blog/{LANG_TO_PATH[lang]}/</code>
            </p>
          </div>
        )}
      </div>

      <Pagination {page} />
    </div>

    <aside class="rsidebar" style="padding:16px 0;">
      <div class="rsidebar-section">
        <div class="rsidebar-head">{t("section.topic")}</div>
        <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;">
          {["BTC", "ETH", "DeFi", "NFT", "Wallet", "Tutorial"].map(tag => (
            <a href={`/tags/${tag.toLowerCase()}`} class="ctag" style="text-decoration:none;">{tag}</a>
          ))}
        </div>
      </div>
    </aside>
  </div>

  <Footer />
</Layout>

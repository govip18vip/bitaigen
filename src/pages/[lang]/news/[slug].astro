---
// src/pages/[lang]/news/[slug].astro — multi-lang news detail page
// SSR/ISR via NewsDetails layout (full SEO + affiliate hooks).
export const prerender = false;

import { toHTML } from "@portabletext/to-html";
import NewsDetails from "@/layouts/NewsDetails.astro";
import { sanityClient, sanityImageUrl } from "@/utils/sanity";
import { LANG_PATH_MAP, type Lang } from "@/i18n/ui";

const { lang: langPath, slug } = Astro.params;
const lang: Lang = LANG_PATH_MAP[langPath ?? ""] ?? "en";

const post = await sanityClient.fetch(`
  *[_type == "btgPost" && slug.current == $slug && lang == $lang && draft != true][0] {
    _id, title, slug, lang, articleType, description,
    coverImage, body, pubDatetime, modDatetime,
    tags, faqs, sourceUrl, sourceName,
    "author": author->{ name, bio, avatar, twitter }
  }
`, { slug, lang });

if (!post) {
  return Astro.redirect("/404");
}

const bodyHtml = post.body
  ? toHTML(post.body, {
      components: {
        types: {
          image: ({ value }: any) => {
            const url = value?.asset?._ref
              ? sanityImageUrl(value.asset._ref, { width: 800 })
              : "";
            const alt = value?.alt || post.title;
            return url
              ? `<figure><img src="${url}" alt="${alt}" loading="lazy" decoding="async" /></figure>`
              : "";
          },
        },
      },
    })
  : "";

const tagList = Array.isArray(post.tags) ? post.tags : [];
const related = tagList.length > 0
  ? await sanityClient.fetch(
      `*[_type == "btgPost" && draft != true && lang == $lang
         && slug.current != $slug
         && count((tags[])[@ in $tags]) > 0
       ] | order(pubDatetime desc) [0...4] {
        _id, title, slug, lang, description, coverImage, pubDatetime, tags
      }`,
      { lang, slug, tags: tagList },
    )
  : [];
---

<NewsDetails post={post} bodyHtml={bodyHtml} related={related} />

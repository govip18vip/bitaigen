---
// src/pages/[lang]/binance/index.astro
// 多语言币安专题 Pillar 页 — /en/binance, /zh-tw/binance, /es/binance, /pt/binance

import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
import { LANG_PATH_MAP, type Lang } from "@/i18n/ui";
import {
  getBinanceSections,
  BINANCE_REF,
  BINANCE_REG_URL,
  BINANCE_DL_APK,
  DIFFICULTY_LABEL,
  binancePillarHreflang,
} from "@/data/binance-i18n";

export function getStaticPaths() {
  return Object.entries(LANG_PATH_MAP).map(([pathSeg, lang]) => ({
    params: { lang: pathSeg },
    props: { lang },
  }));
}

const { lang } = Astro.props as { lang: Lang };
const sections = getBinanceSections(lang);
const diffLabel = DIFFICULTY_LABEL[lang];

const REF  = BINANCE_REF;
const APK  = BINANCE_DL_APK;
const WEB  = BINANCE_REG_URL;
const LOGO = "https://basebiance.com/content/images/2025/04/1HH5201407.png";

const langPathSeg = lang === "zh-TW" ? "zh-tw" : lang;
const canonicalURL = `${SITE.website}${langPathSeg}/binance`;
const hreflangLinks = binancePillarHreflang(SITE.website);

// ── Per-language UI strings ────────────────────────────────
const UI: Record<Lang, {
  metaTitle: string; metaDesc: string; keywords: string;
  h1: string; subtitle: string;
  ctaApk: string; ctaWeb: string; ctaDisclaimer: string;
  refCodeLabel: string; refCopyLabel: string; refCopiedLabel: string; refDiscount: string;
  topicsTitle: string; viewTutorial: string;
  whyTitle: string; whyItems: { icon: string; title: string; desc: string }[];

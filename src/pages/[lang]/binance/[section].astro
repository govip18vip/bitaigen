---
// src/pages/[lang]/binance/[section].astro
// 多语言币安专题子页 — /en/binance/{section}, /zh-tw/binance/{section}, /es/binance/{section}, /pt/binance/{section}

import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
import { LANG_PATH_MAP, type Lang } from "@/i18n/ui";
import {
  getBinanceSections,
  getRelatedSections,
  BINANCE_REG_URL,
  BINANCE_DL_APK,
  BINANCE_REF,
  DIFFICULTY_LABEL,
  DIFFICULTY_COLOR,
  binanceSectionHreflang,
} from "@/data/binance-i18n";

export function getStaticPaths() {
  const paths: any[] = [];
  for (const [pathSeg, lang] of Object.entries(LANG_PATH_MAP)) {
    const sections = getBinanceSections(lang as Lang);
    for (const section of sections) {
      paths.push({
        params: { lang: pathSeg, section: section.id },
        props: { lang, section },
      });
    }
  }
  return paths;
}

const { lang, section } = Astro.props as { lang: Lang; section: any };
const allSections = getBinanceSections(lang);
const related = getRelatedSections(lang, section.relatedSections);
const diffLabel = DIFFICULTY_LABEL[lang];

const REF  = BINANCE_REF;
const APK  = BINANCE_DL_APK;
const WEB  = BINANCE_REG_URL;
const LOGO = "https://basebiance.com/content/images/2025/04/1HH5201407.png";

const langPathSeg = lang === "zh-TW" ? "zh-tw" : lang;
const canonicalURL = `${SITE.website}${langPathSeg}/binance/${section.id}`;
const hreflangLinks = binanceSectionHreflang(SITE.website, section.id);

// ── Per-language UI labels ──
const LABELS: Record<Lang, {
  home: string; binance: string; allTopics: string; topicOverview: string;
  detailedSteps: string; faqTitle: string; relatedTopics: string;
  ctaApk: string; ctaWeb: string; ctaMid: string; ctaBottomTitle: string; ctaBottomSub: string;
}> = {
  "zh-CN": {} as any,
  "zh-TW": {
    home: "首頁", binance: "幣安教學", allTopics: "全部主題", topicOverview: "主題總覽",
    detailedSteps: "詳細步驟", faqTitle: "常見問題", relatedTopics: "相關教學",
    ctaApk: "📱 下載App", ctaWeb: `🌐 網頁註冊（邀請碼 ${REF}）`,
    ctaMid: `使用邀請碼 ${REF} 註冊，享最高手續費折扣`,
    ctaBottomTitle: "立即註冊，終身享折扣",
    ctaBottomSub: "永久有效",
  },
  "en": {
    home: "Home", binance: "Binance Guide", allTopics: "All Topics", topicOverview: "Topic Overview",
    detailedSteps: "Detailed Steps", faqTitle: "Frequently Asked Questions", relatedTopics: "Related Tutorials",
    ctaApk: "📱 Download App", ctaWeb: `🌐 Sign Up (code ${REF})`,
    ctaMid: `Use referral code ${REF} for max trading fee discount`,
    ctaBottomTitle: "Sign Up Now, Get Lifetime Discount",
    ctaBottomSub: "Valid forever",
  },
  "es": {
    home: "Inicio", binance: "Guía Binance", allTopics: "Todos los Temas", topicOverview: "Vista General",
    detailedSteps: "Pasos Detallados", faqTitle: "Preguntas Frecuentes", relatedTopics: "Tutoriales Relacionados",
    ctaApk: "📱 Descargar App", ctaWeb: `🌐 Registro (código ${REF})`,
    ctaMid: `Usa código ${REF} para descuento máximo en comisiones`,
    ctaBottomTitle: "Regístrate Ahora, Descuento de Por Vida",
    ctaBottomSub: "Válido para siempre",
  },
  "pt": {
    home: "Início", binance: "Guia Binance", allTopics: "Todos os Tópicos", topicOverview: "Visão Geral",
    detailedSteps: "Passos Detalhados", faqTitle: "Perguntas Frequentes", relatedTopics: "Tutoriais Relacionados",
    ctaApk: "📱 Baixar App", ctaWeb: `🌐 Cadastro (código ${REF})`,
    ctaMid: `Use código ${REF} para desconto máximo em taxas`,
    ctaBottomTitle: "Cadastre-se Agora, Desconto Vitalício",
    ctaBottomSub: "Válido para sempre",
  },
};
const ui = LABELS[lang];

// ── Schema ────────────────────────────────────────────────
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: section.title,
  description: section.metaDesc,
  url: canonicalURL,
  inLanguage: lang,
  author: { "@type": "Organization", name: "Bitaigen" },
  publisher: {
    "@type": "Organization",
    name: "Bitaigen",
    logo: { "@type": "ImageObject", url: `${SITE.website}favicon.svg` },
  },
  breadcrumb: {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: ui.home, item: SITE.website },
      { "@type": "ListItem", position: 2, name: ui.binance, item: `${SITE.website}${langPathSeg}/binance` },
      { "@type": "ListItem", position: 3, name: section.shortTitle, item: canonicalURL },
    ],
  },
};

const faqSchema = section.faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  inLanguage: lang,
  mainEntity: section.faqs.map((faq: any) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: { "@type": "Answer", text: faq.a },
  })),
} : null;

const howToSchema = section.steps.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: section.title,
  description: section.intro,
  inLanguage: lang,
  estimatedCost: { "@type": "MonetaryAmount", currency: "USD", value: "0" },
  step: section.steps.map((s: any) => ({
    "@type": "HowToStep",
    position: s.step,
    name: s.title,
    text: s.content,
  })),
} : null;

const tipIconMap: Record<string, string> = { warning: "⚠️", success: "✅", info: "💡" };
const tipColorMap: Record<string, string> = {
  warning: "rgba(246,70,93,0.08)",
  success: "rgba(14,203,129,0.08)",
  info:    "rgba(240,185,11,0.08)",
};
const tipBorderMap: Record<string, string> = {
  warning: "rgba(246,70,93,0.3)",
  success: "rgba(14,203,129,0.3)",
  info:    "rgba(240,185,11,0.3)",
};
const tipTextMap: Record<string, string> = {
  warning: "#F6465D",
  success: "#0ECB81",
  info:    "#F0B90B",
};
---

<Layout
  title={section.metaTitle}
  description={section.metaDesc}
  keywords={section.keywords.join(",")}
  canonicalURL={canonicalURL}
>
  <Fragment slot="head">
    {hreflangLinks.map(l => (
      <link rel="alternate" hreflang={l.lang} href={l.href} />
    ))}
    <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
    {howToSchema && <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />}
  </Fragment>

  <Header />

  <style>
    @media(max-width:768px){
      .binance-layout{ grid-template-columns:1fr !important; }
      .binance-sidebar{ display:none !important; }
    }
  </style>

  <div style="max-width:1100px;margin:0 auto;padding:0 16px 80px;display:grid;grid-template-columns:1fr 240px;gap:32px;align-items:start;" class="binance-layout">

    <main id="main-content">

      <!-- 面包屑 -->
      <nav aria-label="breadcrumb" style="font-size:13px;color:var(--fg-muted);padding:20px 0 0;display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
        <a href="/" style="color:var(--fg-muted);text-decoration:none;">{ui.home}</a>
        <span>/</span>
        <a href={`/${langPathSeg}/binance`} style="color:var(--fg-muted);text-decoration:none;">{ui.binance}</a>
        <span>/</span>
        <span style="color:var(--fg);">{section.shortTitle}</span>
      </nav>

      <!-- 文章头 -->
      <header style="padding:24px 0 32px;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;flex-wrap:wrap;">
          <span style="font-size:28px;line-height:1;">{section.icon}</span>
          <span style="font-size:11px;padding:3px 10px;border-radius:20px;font-weight:600;background:rgba(240,185,11,0.12);color:#F0B90B;">⏱ {section.estimatedTime}</span>
          <span style={`font-size:11px;padding:3px 10px;border-radius:20px;font-weight:600;background:${DIFFICULTY_COLOR[section.difficulty]}18;color:${DIFFICULTY_COLOR[section.difficulty]};`}>
            {diffLabel[section.difficulty]}
          </span>
        </div>
        <h1 style="font-size:clamp(20px,3.5vw,30px);font-weight:900;color:var(--fg);line-height:1.25;margin:0 0 14px;letter-spacing:-0.02em;">{section.title}</h1>
        <p style="font-size:15px;color:var(--fg-muted);line-height:1.8;margin:0 0 20px;">{section.intro}</p>

        <div style="display:flex;flex-wrap:wrap;gap:10px;">
          <a href={APK} target="_blank" rel="noopener noreferrer nofollow sponsored"
            style="display:inline-flex;align-items:center;gap:8px;padding:11px 20px;background:#F0B90B;color:#1a1200;border-radius:8px;text-decoration:none;font-weight:700;font-size:14px;">
            {ui.ctaApk}
          </a>
          <a href={WEB} target="_blank" rel="noopener noreferrer nofollow sponsored"
            style="display:inline-flex;align-items:center;gap:8px;padding:11px 20px;background:var(--bg-card);color:var(--fg);border:1.5px solid #F0B90B;border-radius:8px;text-decoration:none;font-weight:600;font-size:14px;">
            {ui.ctaWeb}
          </a>
        </div>
      </header>

      <!-- 提示框 -->
      {section.tips.length > 0 && (
        <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:32px;">
          {section.tips.map((tip: any) => (
            <div style={`background:${tipColorMap[tip.type]};border:1px solid ${tipBorderMap[tip.type]};border-radius:10px;padding:14px 16px;display:flex;gap:10px;`}>
              <span style="font-size:18px;flex-shrink:0;line-height:1.3;">{tipIconMap[tip.type]}</span>
              <div>
                <div style={`font-size:13px;font-weight:700;color:${tipTextMap[tip.type]};margin-bottom:4px;`}>{tip.title}</div>
                <div style="font-size:13px;color:var(--fg-muted);line-height:1.6;">{tip.content}</div>
              </div>
            </div>
          ))}
        </div>
      )}

      <!-- 步骤 -->
      {section.steps.length > 0 && (
        <section style="margin-bottom:36px;">
          <h2 style="font-size:18px;font-weight:800;color:var(--fg);margin:0 0 20px;display:flex;align-items:center;gap:8px;">
            <span style="width:4px;height:20px;background:#F0B90B;border-radius:2px;display:inline-block;"></span>
            {ui.detailedSteps}
          </h2>
          <div style="display:flex;flex-direction:column;gap:0;">
            {section.steps.map((step: any, i: number) => (
              <div style={`display:flex;gap:16px;align-items:flex-start;padding:20px 0;${i < section.steps.length - 1 ? "border-bottom:1px solid var(--border-subtle);" : ""}`}>
                <div style="width:38px;height:38px;border-radius:50%;background:#F0B90B;color:#1a1200;font-size:16px;font-weight:900;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{step.step}</div>
                <div style="flex:1;">
                  <h3 style="font-size:15px;font-weight:700;color:var(--fg);margin:0 0 6px;">{step.title}</h3>
                  <p style="font-size:13.5px;color:var(--fg-muted);line-height:1.75;margin:0;">{step.content}</p>
                  {step.tip && (
                    <div style="margin-top:10px;padding:8px 12px;background:rgba(240,185,11,0.08);border-left:3px solid #F0B90B;border-radius:0 6px 6px 0;font-size:12.5px;color:var(--fg-muted);line-height:1.6;">
                      💡 {step.tip}
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- 中间 CTA -->
      <div style="background:rgba(240,185,11,0.06);border:1.5px dashed rgba(240,185,11,0.4);border-radius:12px;padding:24px;margin-bottom:36px;text-align:center;">
        <p style="font-size:14px;color:var(--fg);font-weight:600;margin:0 0 14px;">{ui.ctaMid}</p>
        <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:center;">
          <a href={APK} target="_blank" rel="noopener noreferrer nofollow sponsored"
            style="display:inline-flex;align-items:center;gap:7px;padding:11px 24px;background:#F0B90B;color:#1a1200;border-radius:8px;text-decoration:none;font-weight:800;font-size:14px;">{ui.ctaApk}</a>
          <a href={WEB} target="_blank" rel="noopener noreferrer nofollow sponsored"
            style="display:inline-flex;align-items:center;gap:7px;padding:11px 24px;background:transparent;color:var(--fg);border:1px solid var(--border);border-radius:8px;text-decoration:none;font-weight:600;font-size:14px;">{ui.ctaWeb}</a>
        </div>
      </div>

      <!-- FAQ -->
      {section.faqs.length > 0 && (
        <section style="margin-bottom:36px;">
          <h2 style="font-size:18px;font-weight:800;color:var(--fg);margin:0 0 18px;display:flex;align-items:center;gap:8px;">
            <span style="width:4px;height:20px;background:#F0B90B;border-radius:2px;display:inline-block;"></span>
            {ui.faqTitle}
          </h2>
          <div style="display:flex;flex-direction:column;gap:10px;">
            {section.faqs.map((faq: any) => (
              <details style="background:var(--bg-card);border:1px solid var(--border);border-radius:10px;padding:14px 16px;cursor:pointer;">
                <summary style="font-size:14px;font-weight:600;color:var(--fg);list-style:none;display:flex;justify-content:space-between;align-items:center;gap:12px;">
                  <span>{faq.q}</span>
                  <span style="color:#F0B90B;font-size:20px;flex-shrink:0;">+</span>
                </summary>
                <p style="font-size:13px;color:var(--fg-muted);line-height:1.75;margin:12px 0 0;">{faq.a}</p>
              </details>
            ))}
          </div>
        </section>
      )}

      <!-- 相关 -->
      {related.length > 0 && (
        <section style="margin-bottom:36px;">
          <h2 style="font-size:16px;font-weight:700;color:var(--fg);margin:0 0 14px;display:flex;align-items:center;gap:8px;">
            <span style="width:3px;height:18px;background:#F0B90B;border-radius:2px;display:inline-block;"></span>
            {ui.relatedTopics}
          </h2>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;">
            {related.map(rel => (
              <a href={`/${langPathSeg}/binance/${rel.id}`}
                style="display:flex;gap:10px;align-items:center;padding:14px;background:var(--bg-card);border:1px solid var(--border);border-radius:10px;text-decoration:none;">
                <span style="font-size:20px;">{rel.icon}</span>
                <div>
                  <div style="font-size:13px;font-weight:700;color:var(--fg);">{rel.shortTitle}</div>
                  <div style="font-size:11px;color:var(--fg-muted);margin-top:2px;">{diffLabel[rel.difficulty]} · {rel.estimatedTime}</div>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- 底部 CTA -->
      <section style="background:linear-gradient(135deg,#1a1200,#2a1e00);border:1px solid rgba(240,185,11,0.3);border-radius:14px;padding:32px;text-align:center;">
        <img src={LOGO} alt="Binance" width="48" height="48" style="border-radius:10px;margin-bottom:14px;" />
        <h2 style="font-size:20px;font-weight:900;color:#F0B90B;margin:0 0 8px;">{ui.ctaBottomTitle}</h2>
        <p style="font-size:13px;color:rgba(255,255,255,0.65);margin:0 0 20px;line-height:1.7;">
          <strong style="color:#F0B90B;font-family:monospace;font-size:17px;">{REF}</strong> — {ui.ctaBottomSub}
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:center;max-width:400px;margin:0 auto;">
          <a href={APK} target="_blank" rel="noopener noreferrer nofollow sponsored"
            style="flex:1;min-width:140px;padding:13px;background:#F0B90B;color:#1a1200;border-radius:8px;text-decoration:none;font-size:14px;font-weight:800;text-align:center;">
            {ui.ctaApk}
          </a>
          <a href={WEB} target="_blank" rel="noopener noreferrer nofollow sponsored"
            style="flex:1;min-width:140px;padding:13px;background:transparent;color:rgba(255,255,255,0.8);border:1px solid rgba(255,255,255,0.25);border-radius:8px;text-decoration:none;font-size:14px;font-weight:600;text-align:center;">
            {ui.ctaWeb}
          </a>
        </div>
      </section>

    </main>

    <!-- 侧边栏 -->
    <aside class="binance-sidebar" style="position:sticky;top:80px;background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:20px;max-height:85vh;overflow-y:auto;">
      <div style="font-size:12px;font-weight:700;color:var(--fg-muted);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:14px;">{ui.allTopics}</div>
      <nav style="display:flex;flex-direction:column;gap:4px;">
        <a href={`/${langPathSeg}/binance`}
          style="display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:7px;text-decoration:none;font-size:12.5px;color:var(--fg-muted);">
          🏠 <span>{ui.topicOverview}</span>
        </a>
        {allSections.map(s => (
          <a href={`/${langPathSeg}/binance/${s.id}`}
            style={`display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:7px;text-decoration:none;font-size:12.5px;${s.id === section.id ? "background:rgba(240,185,11,0.12);color:#F0B90B;font-weight:700;" : "color:var(--fg-muted);"}`}>
            <span>{s.icon}</span>
            <span>{s.shortTitle}</span>
          </a>
        ))}
      </nav>

      <div style="margin-top:18px;padding-top:16px;border-top:1px solid var(--border);">
        <a href={APK} target="_blank" rel="noopener noreferrer nofollow sponsored"
          style="display:flex;align-items:center;justify-content:center;gap:6px;padding:10px;background:#F0B90B;color:#1a1200;border-radius:8px;text-decoration:none;font-weight:700;font-size:13px;margin-bottom:8px;">
          {ui.ctaApk}
        </a>
        <div style="text-align:center;font-size:11px;color:var(--fg-muted);"><span style="color:#F0B90B;font-family:monospace;font-weight:700;">{REF}</span></div>
      </div>
    </aside>

  </div>

  <Footer />
</Layout>

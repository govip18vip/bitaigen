---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
---

<Layout title={`页面未找到 | ${SITE.title}`} description="您访问的页面不存在。">
  <Header />

  <main id="main-content" style="max-width:640px;margin:0 auto;padding:60px 16px 80px;text-align:center;">
    <div style="font-size:80px;margin-bottom:16px;opacity:0.15;">404</div>
    <h1 style="font-size:24px;font-weight:800;color:var(--fg);margin:0 0 8px;">页面未找到</h1>
    <p style="font-size:14px;color:var(--fg-muted);margin:0 0 32px;line-height:1.6;">
      您访问的页面不存在或已被移动。
    </p>

    <div style="max-width:400px;margin:0 auto 40px;">
      <form action="/search" method="get" style="display:flex;gap:8px;">
        <input type="text" name="q" placeholder="搜索文章、教程、行情..."
          style="flex:1;padding:12px 16px;border:2px solid var(--border);border-radius:8px;font-size:14px;background:var(--bg-card);color:var(--fg);outline:none;" />
        <button type="submit"
          style="padding:12px 20px;background:var(--accent);color:#fff;border:none;border-radius:8px;font-weight:700;font-size:14px;cursor:pointer;">
          搜索
        </button>
      </form>
    </div>

    <div style="text-align:left;max-width:400px;margin:0 auto;">
      <h2 style="font-size:16px;font-weight:700;color:var(--fg);margin:0 0 14px;display:flex;align-items:center;gap:8px;">
        <span style="width:3px;height:16px;background:var(--accent);border-radius:2px;"></span>
        热门内容
      </h2>
      <div style="display:flex;flex-direction:column;gap:8px;">
        {[
          { label: "首页", href: "/", icon: "🏠" },
          { label: "新手入门指南", href: "/posts/zh-cn/crypto-beginner-guide-2026-zh-cn", icon: "📚" },
          { label: "交易所排名", href: "/posts/zh-cn/crypto-exchange-ranking-2026-zh-cn", icon: "🏆" },
          { label: "币安注册教程", href: "/go/binance", icon: "🏦" },
          { label: "实时行情", href: "/price", icon: "📊" },
          { label: "全部文章", href: "/posts", icon: "📰" },
        ].map(item => (
          <a href={item.href}
            style="display:flex;align-items:center;gap:10px;padding:12px 14px;background:var(--bg-card);border:1px solid var(--border);border-radius:8px;text-decoration:none;color:var(--fg);font-size:14px;transition:border-color 0.12s;">
            <span>{item.icon}</span>
            <span style="font-weight:500;">{item.label}</span>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

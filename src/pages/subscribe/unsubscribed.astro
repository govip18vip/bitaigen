---
// src/pages/subscribe/unsubscribed.astro
// Shown after GET /api/unsubscribe — email has been removed from audience.
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import { SITE } from "@/config";
import { getLang } from "@/i18n/ui";

export const prerender = false;

const lang = getLang(Astro.url);

const COPY: Record<string, { title: string; h1: string; p: string; home: string }> = {
  "zh-CN": {
    title: "已取消订阅",
    h1:    "您已取消订阅",
    p:     "我们已将您的邮箱从订阅列表中移除。您将不再收到 Bitaigen 的邮件。感谢您曾经的关注，期待未来再次见面。",
    home:  "返回首页",
  },
  "zh-TW": {
    title: "已取消訂閱",
    h1:    "您已取消訂閱",
    p:     "我們已將您的郵箱從訂閱列表中移除。您將不再收到 Bitaigen 的郵件。感謝您曾經的關注，期待未來再次見面。",
    home:  "返回首頁",
  },
  "en": {
    title: "Unsubscribed",
    h1:    "You've been unsubscribed",
    p:     "Your email has been removed from our list. You won't receive any more emails from Bitaigen. Thanks for having been with us — you're welcome back anytime.",
    home:  "Back to home",
  },
  "es": {
    title: "Cancelaste tu suscripción",
    h1:    "Te has dado de baja",
    p:     "Hemos eliminado tu correo de nuestra lista. No recibirás más e-mails de Bitaigen. Gracias por tu interés — vuelve cuando quieras.",
    home:  "Volver al inicio",
  },
  "pt": {
    title: "Inscrição cancelada",
    h1:    "Você cancelou a inscrição",
    p:     "Removemos seu e-mail da nossa lista. Você não receberá mais mensagens do Bitaigen. Obrigado pelo seu interesse — volte quando quiser.",
    home:  "Voltar ao início",
  },
};

const c = COPY[lang] ?? COPY["zh-CN"];
---

<Layout
  title={`${c.title} | ${SITE.title}`}
  description={c.p}
  noindex={true}
>
  <Header />
  <div class="site-outer">
    <LeftSidebar />
    <main class="main-col" style="padding:60px 20px;" id="main-content">
      <div style="max-width:560px;margin:0 auto;text-align:center;">
        <h1 style="font-size:28px;font-weight:800;color:var(--fg);margin:0 0 16px;line-height:1.3;">{c.h1}</h1>
        <p style="font-size:16px;color:var(--fg-muted);line-height:1.7;margin:0 0 32px;">{c.p}</p>
        <a href="/" class="btn-primary" style="display:inline-block;padding:12px 28px;background:var(--accent);color:#fff;border-radius:8px;text-decoration:none;font-weight:700;font-size:14px;">
          {c.home}
        </a>
      </div>
    </main>
  </div>
  <Footer />
</Layout>

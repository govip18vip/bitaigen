---
// src/pages/subscribe/pending.astro
// Landing page shown after POST /api/subscribe — tells the user to check their inbox.
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import { SITE } from "@/config";
import { getLang } from "@/i18n/ui";

export const prerender = false;

const lang = getLang(Astro.url);

const COPY: Record<string, { title: string; h1: string; p1: string; p2: string; home: string }> = {
  "zh-CN": {
    title: "请查收确认邮件",
    h1:    "📬 请查收您的邮箱",
    p1:    "我们已向您的邮箱发送了一封确认邮件。请点击邮件中的确认链接以完成订阅。",
    p2:    "没有收到？请检查垃圾邮件文件夹，或稍后重新订阅。确认链接 24 小时内有效。",
    home:  "返回首页",
  },
  "zh-TW": {
    title: "請查收確認郵件",
    h1:    "📬 請查收您的郵箱",
    p1:    "我們已向您的郵箱發送了一封確認郵件。請點擊郵件中的確認連結以完成訂閱。",
    p2:    "沒有收到？請檢查垃圾郵件資料夾，或稍後重新訂閱。確認連結 24 小時內有效。",
    home:  "返回首頁",
  },
  "en": {
    title: "Check your inbox",
    h1:    "📬 Check your inbox",
    p1:    "We've sent a confirmation email to your address. Click the link in that email to complete your subscription.",
    p2:    "Didn't get it? Check your spam folder, or try again. The confirmation link expires in 24 hours.",
    home:  "Back to home",
  },
  "es": {
    title: "Revisa tu bandeja de entrada",
    h1:    "📬 Revisa tu bandeja",
    p1:    "Te hemos enviado un correo de confirmación. Haz clic en el enlace para completar tu suscripción.",
    p2:    "¿No lo ves? Revisa tu carpeta de spam o inténtalo de nuevo. El enlace caduca en 24 horas.",
    home:  "Volver al inicio",
  },
  "pt": {
    title: "Verifique sua caixa de entrada",
    h1:    "📬 Verifique seu e-mail",
    p1:    "Enviamos um e-mail de confirmação. Clique no link para concluir sua inscrição.",
    p2:    "Não recebeu? Verifique a pasta de spam ou tente novamente. O link expira em 24 horas.",
    home:  "Voltar ao início",
  },
};

const c = COPY[lang] ?? COPY["zh-CN"];
---

<Layout
  title={`${c.title} | ${SITE.title}`}
  description={c.p1}
  noindex={true}
>
  <Header />
  <div class="site-outer">
    <LeftSidebar />
    <main class="main-col" style="padding:60px 20px;" id="main-content">
      <div style="max-width:560px;margin:0 auto;text-align:center;">
        <h1 style="font-size:28px;font-weight:800;color:var(--fg);margin:0 0 16px;line-height:1.3;">{c.h1}</h1>
        <p style="font-size:16px;color:var(--fg-muted);line-height:1.7;margin:0 0 16px;">{c.p1}</p>
        <p style="font-size:14px;color:var(--fg-light);line-height:1.6;margin:0 0 32px;">{c.p2}</p>
        <a href="/" class="btn-primary" style="display:inline-block;padding:12px 28px;background:var(--accent);color:#fff;border-radius:8px;text-decoration:none;font-weight:700;font-size:14px;">
          {c.home}
        </a>
      </div>
    </main>
  </div>
  <Footer />
</Layout>

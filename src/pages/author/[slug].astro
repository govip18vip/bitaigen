---
// src/pages/author/[slug].astro
// 作者主页 — E-E-A-T 信号核心页面
// 每位作者对应 /author/bitaigen/ 等路径，Article schema 的 author.url 指向此处

import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import { SITE } from "@/config";
import { getAllAuthors, getAuthor } from "@/utils/authors";
import { getPath } from "@/utils/getPath";
import { getLang, useTranslations } from "@/i18n/ui";

export const getStaticPaths = (async () => {
  return getAllAuthors().map(a => ({
    params: { slug: a.slug },
  }));
}) satisfies GetStaticPaths;

const { slug } = Astro.params;
const author = getAuthor(slug);
const lang = getLang(Astro.url);
const t = useTranslations(lang);

// 获取该作者的所有文章
const allPosts = await getCollection("blog");
const authorPosts = allPosts
  .filter(p => !p.data.draft &&
    (p.data.author ?? SITE.author).toLowerCase().replace(/\s+/g, "-") === slug
  )
  .sort((a, b) => new Date(b.data.pubDatetime).getTime() - new Date(a.data.pubDatetime).getTime());

const pageTitle = `${author.name} | ${author.title[lang] ?? author.title["zh-CN"]} | ${SITE.title}`;
const pageDesc  = author.bio[lang] ?? author.bio["zh-CN"];

// Person schema
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${Astro.url.origin}/author/${slug}/#person`,
  name: author.name,
  url: `${Astro.url.origin}/author/${slug}/`,
  description: pageDesc,
  image: author.avatar.startsWith("http") ? author.avatar : `${Astro.url.origin}${author.avatar}`,
  jobTitle: author.title[lang] ?? author.title["zh-CN"],
  worksFor: {
    "@type": "Organization",
    "@id": `${Astro.url.origin}/#organization`,
    name: SITE.title,
  },
  knowsAbout: author.expertise,
  sameAs: [author.twitter, author.telegram, author.linkedin, author.website].filter(Boolean),
};
---

<Layout title={pageTitle} description={pageDesc} ogType="profile">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </Fragment>

  <Header />
  <div class="site-outer">
    <LeftSidebar currentLang={lang} />

    <main class="main-col" id="main-content" style="padding-bottom:40px;">

      <!-- 面包屑 -->
      <nav style="padding:12px 16px 0;font-size:13px;color:var(--fg-muted);">
        <a href="/" style="color:var(--fg-muted);text-decoration:none;">{t("nav.home")}</a>
        <span style="margin:0 6px;opacity:0.5;">›</span>
        <span style="color:var(--fg);">{author.name}</span>
      </nav>

      <!-- 作者 Hero 卡片 -->
      <section style="padding:16px 16px 0;">
        <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:28px 28px 24px;display:flex;gap:24px;flex-wrap:wrap;align-items:flex-start;">

          <!-- 头像 -->
          <div style="flex-shrink:0;">
            <div style="width:88px;height:88px;border-radius:50%;overflow:hidden;border:3px solid var(--accent);box-shadow:0 0 0 4px rgba(247,147,26,.15);">
              <img src={author.avatar} alt={author.name}
                width="88" height="88"
                style="width:100%;height:100%;object-fit:cover;"
                onerror="this.style.display='none'" />
            </div>
          </div>

          <!-- 信息 -->
          <div style="flex:1;min-width:200px;">
            <h1 style="font-size:22px;font-weight:800;color:var(--fg);margin:0 0 4px;">{author.name}</h1>
            <p style="font-size:13px;color:var(--accent);font-weight:600;margin:0 0 14px;">
              {author.title[lang] ?? author.title["zh-CN"]}
            </p>
            <p style="font-size:14px;color:var(--fg-muted);line-height:1.7;margin:0 0 16px;max-width:600px;">
              {author.bio[lang] ?? author.bio["zh-CN"]}
            </p>

            <!-- 专业领域标签 -->
            <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px;">
              {author.expertise.map(tag => (
                <span style="display:inline-block;padding:3px 10px;border-radius:4px;font-size:11.5px;font-weight:600;background:var(--tag-orange-bg);color:var(--accent);">
                  {tag}
                </span>
              ))}
            </div>

            <!-- 社交链接 -->
            <div style="display:flex;gap:10px;flex-wrap:wrap;">
              {author.twitter && (
                <a href={author.twitter} target="_blank" rel="noopener noreferrer me" class="author-social-link">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  Twitter / X
                </a>
              )}
              {author.telegram && (
                <a href={author.telegram} target="_blank" rel="noopener noreferrer me" class="author-social-link">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
                  Telegram
                </a>
              )}
            </div>
          </div>

          <!-- 统计数字 -->
          <div style="display:flex;flex-direction:column;align-items:center;gap:4px;padding:16px 20px;background:var(--bg-elevated);border-radius:8px;border:1px solid var(--border);min-width:90px;text-align:center;flex-shrink:0;">
            <span style="font-size:28px;font-weight:800;color:var(--accent);">{authorPosts.length}</span>
            <span style="font-size:11px;color:var(--fg-muted);font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">
              {lang === "en" ? "Articles" : lang === "es" ? "Artículos" : lang === "pt" ? "Artigos" : "篇文章"}
            </span>
          </div>
        </div>
      </section>

      <!-- 文章列表 -->
      <section style="padding:20px 16px 0;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:14px;">
          <span style="width:3px;height:18px;background:var(--accent);border-radius:2px;display:inline-block;"></span>
          <h2 style="font-size:16px;font-weight:700;color:var(--fg);margin:0;">
            {lang === "en" ? "Published Articles" : lang === "es" ? "Artículos Publicados" : lang === "pt" ? "Artigos Publicados" : "发布的文章"}
          </h2>
        </div>

        {authorPosts.length === 0 ? (
          <p style="color:var(--fg-muted);font-size:14px;padding:20px 0;">
            {lang === "en" ? "No articles yet." : "暂无文章。"}
          </p>
        ) : (
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:8px;overflow:hidden;">
            {authorPosts.map((post, i) => (
              <a href={getPath(post.id, post.filePath)}
                class:list={["author-post-row", { "has-border": i < authorPosts.length - 1 }]}>
                <div style="flex:1;min-width:0;">
                  <div style="font-size:13.5px;font-weight:600;line-height:1.5;margin-bottom:4px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                    {post.data.title}
                  </div>
                  {post.data.description && (
                    <div style="font-size:12px;color:var(--fg-muted);line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                      {post.data.description}
                    </div>
                  )}
                  <div style="font-size:11px;color:var(--fg-light);margin-top:6px;">
                    {new Date(post.data.pubDatetime).toLocaleDateString(
                      lang === "en" ? "en-US" : lang === "es" ? "es-ES" : lang === "pt" ? "pt-BR" : "zh-CN",
                      { year: "numeric", month: "long", day: "numeric" }
                    )}
                  </div>
                </div>
                {post.data.heroImage && (
                  <div style="width:72px;height:56px;border-radius:6px;overflow:hidden;flex-shrink:0;">
                    <img src={typeof post.data.heroImage === "string" ? post.data.heroImage : (post.data.heroImage as any)?.src}
                      alt="" width="72" height="56"
                      style="width:100%;height:100%;object-fit:cover;" />
                  </div>
                )}
              </a>
            ))}
          </div>
        )}
      </section>

    </main>
  </div>
  <Footer />
</Layout>

<style>
.author-social-link {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 12.5px;
  color: var(--fg-muted);
  text-decoration: none;
  padding: 5px 12px;
  border: 1px solid var(--border);
  border-radius: 5px;
  transition: border-color .15s, color .15s;
}
.author-social-link:hover {
  border-color: var(--accent);
  color: var(--accent);
}
.author-post-row {
  display: flex;
  gap: 14px;
  padding: 14px 16px;
  text-decoration: none;
  color: var(--fg);
  transition: background .12s;
}
.author-post-row.has-border {
  border-bottom: 1px solid var(--border-subtle);
}
.author-post-row:hover {
  background: var(--bg-elevated);
}
</style>

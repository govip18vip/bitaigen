---
// src/components/RelatedPosts.astro
// Shows related articles based on shared tags
import type { CollectionEntry } from "astro:content";
import { getPath } from "@/utils/getPath";
import { useTranslations, type Lang } from "@/i18n/ui";

interface Props {
  currentPost: CollectionEntry<"blog">;
  allPosts: CollectionEntry<"blog">[];
  lang?: Lang;
  max?: number;
}

const { currentPost, allPosts, lang = "zh-CN", max = 4 } = Astro.props;
const t = useTranslations(lang);

const currentTags = (currentPost.data.tags ?? []).map(t => t.toLowerCase());

// Score each post by number of shared tags, exclude current
const scored = allPosts
  .filter(p => p.id !== currentPost.id)
  .filter(p => {
    const pLang = (p.data as any).lang ?? "zh-CN";
    return pLang === lang;
  })
  .map(p => {
    const pTags = (p.data.tags ?? []).map(t => t.toLowerCase());
    const shared = pTags.filter(t => currentTags.includes(t)).length;
    return { post: p, score: shared };
  })
  .filter(s => s.score > 0)
  .sort((a, b) => b.score - a.score || b.post.data.pubDatetime.getTime() - a.post.data.pubDatetime.getTime())
  .slice(0, max);
---

{scored.length > 0 && (
  <section class="related-posts">
    <h2 class="related-posts-title">
      {t("section.related")}
    </h2>
    <div class="related-posts-grid">
      {scored.map(({ post: p }) => (
        <a href={getPath(p.id, p.filePath)} class="related-card">
          {(p.data.heroImage || p.data.ogImage) ? (
            <img
              src={typeof (p.data.heroImage ?? p.data.ogImage) === "string" ? (p.data.heroImage ?? p.data.ogImage) as string : ((p.data.heroImage ?? p.data.ogImage) as any)?.src}
              alt={p.data.title}
              loading="lazy"
              class="related-card-img"
            />
          ) : (
            <div class="related-card-img related-card-placeholder">
              <span>&#8383;</span>
            </div>
          )}
          <div class="related-card-body">
            {p.data.tags?.[0] && (
              <span class="ctag" style="font-size:10px;padding:1px 6px;">{p.data.tags[0]}</span>
            )}
            <h3 class="related-card-title">{p.data.title}</h3>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .related-posts {
    margin-top: 28px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }
  .related-posts-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--fg);
    margin: 0 0 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .related-posts-title::before {
    content: '';
    display: block;
    width: 3px;
    height: 16px;
    background: var(--accent);
    border-radius: 2px;
    flex-shrink: 0;
  }
  .related-posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .related-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    background: var(--bg-card);
    transition: border-color 0.15s, transform 0.15s;
  }
  .related-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .related-card-img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
    background: var(--bg-elevated);
  }
  .related-card-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    opacity: 0.15;
    color: var(--fg);
  }
  .related-card-body {
    padding: 10px 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .related-card-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--fg);
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (max-width: 500px) {
    .related-posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

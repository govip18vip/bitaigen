---
// src/components/CategoryList.astro
// 共享分类列表页 UI（被 6 个分类的 index.astro 复用）
//
// 提供：分页 + 标签筛选 + ItemList JSON-LD + Breadcrumb + 卡片列表
// 输入：category(slug), lang, totalCount, posts, page, pageSize, baseHref
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeftSidebar from "@/components/LeftSidebar.astro";
import { SITE } from "@/config";
import {
  BTG_CATEGORY_LABELS, buildBtgPostHref,
  buildCategoryListHref, type BtgCategory,
} from "@/utils/btgPostRoute";
import type { Lang } from "@/i18n/ui";

export interface Props {
  category: BtgCategory;
  lang: Lang;
  posts: any[];
  totalCount: number;
  page: number;
  pageSize: number;
  hasNext: boolean;
  filterTag?: string;
}

const { category, lang, posts, totalCount, page, pageSize, hasNext, filterTag } = Astro.props;

const categoryLabel = BTG_CATEGORY_LABELS[category][lang]
  || BTG_CATEGORY_LABELS[category]["en"]
  || category;

const totalPages = Math.max(1, Math.ceil(totalCount / pageSize));
const baseHref = buildCategoryListHref(lang, category);
const siteBase = SITE.website.replace(/\/$/, "");

function pageHref(p: number): string {
  const ps = new URLSearchParams();
  if (filterTag) ps.set("tag", filterTag);
  if (p > 1) ps.set("page", String(p));
  const qs = ps.toString();
  return qs ? `${baseHref}?${qs}` : baseHref;
}

const canonicalUrl = `${siteBase}${pageHref(page)}`;
const prevUrl = page > 1 ? `${siteBase}${pageHref(page - 1)}` : null;
const nextUrl = hasNext ? `${siteBase}${pageHref(page + 1)}` : null;

// SEO: 多语言 title / description
const TITLE_TPL: Record<Lang, (cat: string, tag?: string, p?: number) => string> = {
  "zh-CN": (c, t, p) => `${c}${t ? ` · #${t}` : ""}${p && p > 1 ? ` · 第${p}页` : ""} | ${SITE.title}`,
  "zh-TW": (c, t, p) => `${c}${t ? ` · #${t}` : ""}${p && p > 1 ? ` · 第${p}頁` : ""} | ${SITE.title}`,
  "en":    (c, t, p) => `${c}${t ? ` · #${t}` : ""}${p && p > 1 ? ` · Page ${p}` : ""} | ${SITE.title}`,
  "es":    (c, t, p) => `${c}${t ? ` · #${t}` : ""}${p && p > 1 ? ` · Página ${p}` : ""} | ${SITE.title}`,
  "pt":    (c, t, p) => `${c}${t ? ` · #${t}` : ""}${p && p > 1 ? ` · Página ${p}` : ""} | ${SITE.title}`,
};
const DESC_TPL: Record<Lang, (cat: string) => string> = {
  "zh-CN": (c) => `Bitaigen ${c}：精选加密货币、区块链相关${c}内容，覆盖最新行业动态、教程指南与深度分析。`,
  "zh-TW": (c) => `Bitaigen ${c}：精選加密貨幣、區塊鏈相關${c}內容，涵蓋最新行業動態、教學指南與深度分析。`,
  "en":    (c) => `Bitaigen ${c}: curated crypto and blockchain content covering market news, tutorials, and in-depth analysis.`,
  "es":    (c) => `Bitaigen ${c}: contenido cuidadosamente seleccionado sobre criptomonedas y blockchain — noticias, tutoriales y análisis.`,
  "pt":    (c) => `Bitaigen ${c}: conteúdo selecionado sobre criptomoedas e blockchain — notícias, tutoriais e análises.`,
};

const pageTitle = TITLE_TPL[lang](categoryLabel, filterTag, page);
const pageDesc = DESC_TPL[lang](categoryLabel);

const HOME_LABEL: Record<Lang, string> = {
  "zh-CN": "首页", "zh-TW": "首頁",
  "en": "Home", "es": "Inicio", "pt": "Início",
};

// ── Schema ──
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: filterTag ? `#${filterTag} ${categoryLabel}` : categoryLabel,
  description: pageDesc,
  inLanguage: lang,
  url: canonicalUrl,
  isPartOf: { "@type": "WebSite", name: SITE.title, url: siteBase },
  ...(posts.length > 0 && {
    mainEntity: {
      "@type": "ItemList",
      numberOfItems: totalCount,
      itemListElement: posts.map((p: any, i: number) => ({
        "@type": "ListItem",
        position: (page - 1) * pageSize + i + 1,
        url: `${siteBase}${buildBtgPostHref(p.lang || lang, p.category, p.slug?.current, p.articleType)}`,
        name: p.title,
      })),
    },
  }),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: HOME_LABEL[lang], item: siteBase + (lang === "zh-CN" ? "" : `/${lang.toLowerCase()}`) },
    { "@type": "ListItem", position: 2, name: categoryLabel, item: `${siteBase}${baseHref}` },
    ...(filterTag ? [{ "@type": "ListItem", position: 3, name: `#${filterTag}`, item: canonicalUrl }] : []),
  ],
};

function formatDate(dt: string): string {
  const locale = lang === "zh-CN" || lang === "zh-TW" ? "zh-CN" : lang;
  return new Date(dt).toLocaleDateString(locale, { year: "numeric", month: "2-digit", day: "2-digit" });
}
---

<Layout title={pageTitle} description={pageDesc}>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    {prevUrl && <link rel="prev" href={prevUrl} />}
    {nextUrl && <link rel="next" href={nextUrl} />}
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Header />

  <div class="mx-auto flex max-w-6xl">
    <LeftSidebar />

    <main class="flex-1 min-w-0 px-4 py-8">
      <!-- 面包屑 -->
      <nav class="mb-3 text-sm text-[var(--fg-muted)]">
        <a href={lang === "zh-CN" ? "/" : `/${lang.toLowerCase()}`} class="hover:underline">{HOME_LABEL[lang]}</a>
        <span class="mx-2">/</span>
        <span class="text-foreground">{categoryLabel}</span>
        {filterTag && (
          <>
            <span class="mx-2">/</span>
            <span class="text-foreground">#{filterTag}</span>
          </>
        )}
      </nav>

      <h1 class="mb-2 text-3xl font-bold">{categoryLabel}</h1>
      <p class="mb-8 text-[var(--fg-muted)]">{pageDesc}</p>

      {posts.length === 0 ? (
        <div class="rounded-lg border border-[var(--border)] p-12 text-center text-[var(--fg-muted)]">
          {lang === "zh-CN" ? "该分类暂无文章" : lang === "zh-TW" ? "該分類暫無文章" : "No articles in this category yet"}
        </div>
      ) : (
        <ul class="space-y-5">
          {posts.map((p: any) => {
            const href = buildBtgPostHref(p.lang || lang, p.category, p.slug?.current || "", p.articleType);
            return (
              <li class="rounded-lg border border-[var(--border)] bg-[var(--bg-card)] p-5 transition-colors hover:border-[var(--accent)]">
                <a href={href} class="block">
                  <h3 class="mb-2 text-xl font-semibold leading-snug">{p.title}</h3>
                  {p.description && (
                    <p class="mb-3 line-clamp-2 text-sm text-[var(--fg-muted)]">{p.description}</p>
                  )}
                  <div class="flex flex-wrap items-center gap-2 text-xs text-[var(--fg-muted)]">
                    {p.pubDatetime && <span>{formatDate(p.pubDatetime)}</span>}
                    {(p.tags || []).slice(0, 4).map((t: string) => (
                      <span class="rounded bg-[var(--bg-elevated)] px-2 py-0.5">#{t}</span>
                    ))}
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      )}

      <!-- 分页 -->
      {totalPages > 1 && (
        <nav class="mt-10 flex items-center justify-center gap-2" aria-label="Pagination">
          {page > 1 && (
            <a href={pageHref(page - 1)} class="rounded border border-[var(--border)] px-3 py-2 text-sm hover:bg-[var(--bg-elevated)]">
              ←
            </a>
          )}
          <span class="px-3 py-2 text-sm text-[var(--fg-muted)]">
            {page} / {totalPages}
          </span>
          {hasNext && (
            <a href={pageHref(page + 1)} class="rounded border border-[var(--border)] px-3 py-2 text-sm hover:bg-[var(--bg-elevated)]">
              →
            </a>
          )}
        </nav>
      )}
    </main>
  </div>

  <Footer />
</Layout>

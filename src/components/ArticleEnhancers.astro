---
// src/components/ArticleEnhancers.astro
// 文章详情页的"软装"增强：
//   1. 顶部阅读进度条（随滚动填充）
//   2. 浮动 Sticky TOC（侧栏目录，desktop 在右侧；mobile 折叠在顶部）
//   3. 滚动到顶/底按钮（mobile 友好）
//
// 这些组件都是渐进增强：纯 CSS + 少量 JS，不影响主内容渲染。
---

<!-- 1. 顶部阅读进度条 -->
<div id="reading-progress-bar" aria-hidden="true"></div>

<!-- 2. Sticky TOC（PC 右侧浮动 + 移动端顶部折叠） -->
<aside id="article-toc" class="art-toc" aria-label="文章目录">
  <button class="art-toc-mobile-btn" id="art-toc-mobile-btn" aria-expanded="false">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <line x1="8" y1="6" x2="21" y2="6"></line>
      <line x1="8" y1="12" x2="21" y2="12"></line>
      <line x1="8" y1="18" x2="21" y2="18"></line>
      <circle cx="3" cy="6" r="1.5"></circle>
      <circle cx="3" cy="12" r="1.5"></circle>
      <circle cx="3" cy="18" r="1.5"></circle>
    </svg>
    <span class="art-toc-mobile-label">本文目录</span>
    <svg class="art-toc-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <path d="M6 9l6 6 6-6" />
    </svg>
  </button>
  <nav class="art-toc-list" id="art-toc-list" aria-label="目录列表">
    <div class="art-toc-title">本文目录</div>
    <ol id="art-toc-items"></ol>
  </nav>
</aside>

<!-- 3. 回顶部浮钮（mobile + desktop） -->
<button id="back-to-top" class="art-back-top" aria-label="回到顶部">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M18 15l-6-6-6 6"></path>
  </svg>
</button>

<style>
  /* ── 1. 顶部阅读进度条 ── */
  #reading-progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    width: 0;
    background: linear-gradient(90deg, var(--accent), color-mix(in srgb, var(--accent) 60%, #fff));
    z-index: 9999;
    transition: width 0.05s linear;
    pointer-events: none;
  }

  /* ── 2. Sticky TOC ── */
  .art-toc {
    position: fixed;
    top: 80px;
    right: 24px;
    width: 220px;
    max-height: calc(100vh - 120px);
    z-index: 50;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    transition: opacity 0.2s, transform 0.2s;
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
  }
  .art-toc.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .art-toc-mobile-btn { display: none; }
  .art-toc-list {
    padding: 14px 12px;
    overflow-y: auto;
    max-height: calc(100vh - 120px);
  }
  .art-toc-title {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
    margin-bottom: 10px;
    padding: 0 4px;
  }
  .art-toc-list ol {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: toc;
  }
  .art-toc-list li {
    margin: 0;
    counter-increment: toc;
  }
  .art-toc-list a {
    display: block;
    padding: 6px 8px;
    font-size: 12.5px;
    line-height: 1.5;
    color: var(--fg-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: all 0.15s;
    border-radius: 0 4px 4px 0;
  }
  .art-toc-list a:hover {
    color: var(--fg);
    background: color-mix(in srgb, var(--accent) 5%, transparent);
  }
  .art-toc-list a.is-active {
    color: var(--accent);
    border-left-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    font-weight: 600;
  }
  .art-toc-list li.toc-h3 a {
    padding-left: 18px;
    font-size: 12px;
  }

  /* ── 3. Back to top ── */
  .art-back-top {
    position: fixed;
    bottom: 100px;
    right: 24px;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--fg);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 49;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.2s, transform 0.2s, background 0.15s;
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
  }
  .art-back-top.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .art-back-top:hover { background: var(--bg-elevated); border-color: var(--accent); }

  /* ── 响应式：≤1280 隐藏右侧浮动 TOC，改为顶部折叠 ── */
  @media (max-width: 1280px) {
    .art-toc {
      position: relative;
      top: auto;
      right: auto;
      width: 100%;
      max-width: 760px;
      margin: 16px auto 24px;
      max-height: none;
      opacity: 1;
      transform: none;
      pointer-events: auto;
    }
    .art-toc-mobile-btn {
      display: flex;
      align-items: center;
      gap: 8px;
      width: 100%;
      padding: 12px 16px;
      background: transparent;
      border: none;
      color: var(--fg);
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      text-align: left;
    }
    .art-toc-mobile-label { flex: 1; }
    .art-toc-chevron { transition: transform 0.2s; opacity: 0.6; }
    .art-toc[data-expanded="true"] .art-toc-chevron { transform: rotate(180deg); }
    .art-toc-list { display: none; padding: 0 16px 14px; }
    .art-toc[data-expanded="true"] .art-toc-list { display: block; }
    .art-toc-title { display: none; }
  }

  @media (max-width: 640px) {
    .art-back-top { bottom: 90px; right: 16px; }
    .art-toc { margin: 12px 16px 20px; }
  }
</style>

<script>
  // ── 顶部阅读进度条 ──
  function initProgressBar() {
    const bar = document.getElementById("reading-progress-bar") as HTMLElement | null;
    const article = document.getElementById("article") as HTMLElement | null;
    if (!bar || !article) return;
    const _bar = bar;
    const _art = article;

    function update() {
      const rect = _art.getBoundingClientRect();
      const total = _art.offsetHeight - window.innerHeight;
      if (total <= 0) {
        _bar.style.width = "0%";
        return;
      }
      const scrolled = -rect.top;
      const pct = Math.max(0, Math.min(100, (scrolled / total) * 100));
      _bar.style.width = pct + "%";
    }

    window.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", update, { passive: true });
    update();
  }

  // ── Sticky TOC 自动生成 + 滚动联动 ──
  function initToc() {
    const article = document.getElementById("article");
    const tocItems = document.getElementById("art-toc-items");
    const tocBox = document.getElementById("article-toc");
    if (!article || !tocItems || !tocBox) return;

    const headings = article.querySelectorAll<HTMLElement>("h2, h3");
    if (headings.length < 3) {
      // 章节太少不显示 TOC
      tocBox.style.display = "none";
      return;
    }

    // 给每个标题加 id（如果没有）
    const items: { id: string; level: number; text: string; el: HTMLElement }[] = [];
    headings.forEach((h, idx) => {
      if (!h.id) {
        const slug = (h.textContent || "")
          .trim()
          .toLowerCase()
          .replace(/[\s\W]+/g, "-")
          .replace(/^-+|-+$/g, "")
          .slice(0, 60) || `section-${idx}`;
        h.id = slug;
      }
      items.push({
        id: h.id,
        level: parseInt(h.tagName.substring(1), 10),
        text: h.textContent?.trim() || "",
        el: h,
      });
    });

    // 渲染 TOC
    tocItems.innerHTML = items
      .map(
        (it) =>
          `<li class="toc-h${it.level}"><a href="#${it.id}" data-toc-id="${it.id}">${it.text}</a></li>`,
      )
      .join("");

    const _tocBox = tocBox;
    // 桌面端：滚到首个 H2 时显示 TOC
    function checkTocVisibility() {
      if (window.innerWidth <= 1280) return;
      const firstH = items[0]?.el;
      if (!firstH) return;
      const rect = firstH.getBoundingClientRect();
      if (rect.top < window.innerHeight * 0.5) {
        _tocBox.classList.add("is-visible");
      } else {
        _tocBox.classList.remove("is-visible");
      }
    }
    window.addEventListener("scroll", checkTocVisibility, { passive: true });
    window.addEventListener("resize", checkTocVisibility, { passive: true });
    checkTocVisibility();

    // 移动端：折叠按钮
    const mobileBtn = document.getElementById("art-toc-mobile-btn");
    mobileBtn?.addEventListener("click", () => {
      const expanded = tocBox.getAttribute("data-expanded") === "true";
      tocBox.setAttribute("data-expanded", expanded ? "false" : "true");
      mobileBtn.setAttribute("aria-expanded", expanded ? "false" : "true");
    });

    // IntersectionObserver 高亮当前章节
    const linkMap = new Map<string, HTMLAnchorElement>();
    tocItems.querySelectorAll<HTMLAnchorElement>("a[data-toc-id]").forEach((a) => {
      linkMap.set(a.dataset.tocId || "", a);
    });

    let activeId = "";
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            if (id !== activeId) {
              const prev = linkMap.get(activeId);
              if (prev) prev.classList.remove("is-active");
              activeId = id;
              const cur = linkMap.get(activeId);
              if (cur) cur.classList.add("is-active");
            }
          }
        }
      },
      { rootMargin: "-15% 0px -70% 0px", threshold: 0 },
    );
    items.forEach((it) => observer.observe(it.el));

    // 平滑滚动 + 偏移修正（防止被 sticky header 挡）
    tocItems.querySelectorAll<HTMLAnchorElement>("a").forEach((a) => {
      a.addEventListener("click", (e) => {
        e.preventDefault();
        const id = a.dataset.tocId || "";
        const target = document.getElementById(id);
        if (!target) return;
        const top = target.getBoundingClientRect().top + window.pageYOffset - 80;
        window.scrollTo({ top, behavior: "smooth" });
        // 移动端点完自动折叠
        if (window.innerWidth <= 1280) {
          tocBox.setAttribute("data-expanded", "false");
        }
      });
    });
  }

  // ── 回顶部按钮 ──
  function initBackToTop() {
    const btn = document.getElementById("back-to-top");
    if (!btn) return;
    function check() {
      if (window.pageYOffset > 600) {
        btn!.classList.add("is-visible");
      } else {
        btn!.classList.remove("is-visible");
      }
    }
    window.addEventListener("scroll", check, { passive: true });
    btn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
    check();
  }

  function initAll() {
    initProgressBar();
    initToc();
    initBackToTop();
  }

  initAll();
  // 兼容 Astro View Transitions
  document.addEventListener("astro:after-swap", initAll);
</script>

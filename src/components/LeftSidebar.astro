---
// src/components/LeftSidebar.astro
// 所有导航链接都是语言感知的，语言按钮是真实 <a> 链接。
import IconSearch from "@/assets/icons/IconSearch.svg";
import { SITE } from "@/config";
import {
  LANGUAGES, TAXONOMY, DEFAULT_LANG,
  getLang, LANG_TO_PATH, stripLangPrefix,
  type Lang,
} from "@/i18n/ui";

type Props = { currentLang?: Lang };
const { currentLang } = Astro.props;

// 优先使用外部传入的语言（文章页），其次从 URL 识别
const lang: Lang = currentLang ?? getLang(Astro.url);
const langSeg = LANG_TO_PATH[lang]; // "" | "en" | "zh-tw" | "es" | "pt"
const cleanPath = stripLangPrefix(Astro.url.pathname);

// 语言感知的基础路径前缀
const base = langSeg ? `/${langSeg}` : "";

// 判断当前路径是否处于某个导航项下（忽略语言前缀）
const isActive = (p: string) => {
  if (p === "/") return cleanPath === "/" || cleanPath === "";
  return cleanPath.startsWith(p);
};

// 构建切换到目标语言时的链接
// 如果当前在文章详情页，切换语言只能去目标语言首页
function langSwitchHref(targetLang: Lang): string {
  const seg = LANG_TO_PATH[targetLang];
  const targetBase = seg ? `/${seg}` : "";
  // 文章详情页：cleanPath 形如 /posts/xxx，直接去目标首页
  if (cleanPath.startsWith("/posts/") && cleanPath.split("/").length > 3) {
    return seg ? `/${seg}/` : "/";
  }
  // 其他页面（首页、文章列表）：保持路径，换语言
  const path = cleanPath === "/" || cleanPath === "" ? "" : cleanPath;
  return `${targetBase}${path}` || "/";
}

const shortLabel: Record<Lang, string> = {
  "zh-CN": "简中",
  "zh-TW": "繁中",
  "en":    "EN",
  "es":    "ES",
  "pt":    "PT",
};

const langList = Object.entries(LANGUAGES) as [Lang, string][];
---

<aside class="lsidebar" role="navigation" aria-label="主导航">

  <!-- Logo -->
  <a href={base + "/"} class="lsidebar-logo" aria-label={SITE.title}>
    <div class="lsidebar-logo-icon" aria-hidden="true">₿</div>
    <span class="lsidebar-logo-text" data-i18n="site.name">{SITE.title}</span>
  </a>

  <!-- Mobile hamburger -->
  <button id="mobile-nav-btn" class="mobile-ham-btn"
    aria-label="Toggle menu" aria-expanded="false" aria-controls="lnav">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
      stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <line x1="3" y1="6"  x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
  </button>

  <!-- ── Navigation ── -->
  <nav class="lnav" id="lnav">

    <!-- 首页 -->
    <a href={base + "/"}
      class:list={["lnav-item", {
        active: isActive("/") && !isActive("/posts") && !isActive("/tags")
                && !isActive("/search") && !isActive("/about") && !isActive("/archives"),
      }]}>
      <span data-i18n="nav.home">首页</span>
    </a>

    <!-- 快讯 -->
    <a href="/tags/快讯" class:list={["lnav-item", { active: isActive("/tags/快讯") }]}>
      <span data-i18n="nav.flash">快讯</span>
    </a>

    <!-- 资讯（文章列表，语言感知） -->
    <a href={base + "/posts/"}
      class:list={["lnav-item", { active: isActive("/posts") }]}>
      <span data-i18n="nav.news">资讯</span>
    </a>

    <!-- Taxonomy 分组 -->
    {TAXONOMY.slice(2).map(cat => (
      <div class="lnav-group" id={`group-${cat.key}`}>
        {cat.sub.length > 0 ? (
          <button
            class:list={["lnav-item lnav-toggle", { active: isActive(cat.href) }]}
            aria-expanded={isActive(cat.href) ? "true" : "false"}
            data-group={cat.key}
          >
            <span data-i18n={`cat.${cat.key}`}>{cat.key}</span>
            <svg class="arrow" width="11" height="11" viewBox="0 0 12 12" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M4 2l4 4-4 4"/>
            </svg>
          </button>
        ) : (
          <a href={cat.href} class:list={["lnav-item", { active: isActive(cat.href) }]}>
            <span data-i18n={`cat.${cat.key}`}>{cat.key}</span>
          </a>
        )}
        {cat.sub.length > 0 && (
          <div class:list={["lnav-sub", { open: isActive(cat.href) }]} id={`sub-${cat.key}`}>
            {(cat.sub as readonly { key: string; labelKey: string; href: string }[]).map(sub => (
              <a href={sub.href}
                class:list={["lnav-sub-link", { active: isActive(sub.href) }]}
                data-i18n={sub.labelKey}>
                {sub.key}
              </a>
            ))}
          </div>
        )}
      </div>
    ))}

    <div class="lnav-divider" />

    <a href="/search" class:list={["lnav-item", { active: isActive("/search") }]}>
      <span style="display:flex;align-items:center;gap:6px;">
        <IconSearch style="width:14px;height:14px;flex-shrink:0;" />
        <span data-i18n="nav.search">搜索</span>
      </span>
    </a>

    <a href="/about" class:list={["lnav-item", { active: isActive("/about") }]}>
      <span data-i18n="nav.about">关于</span>
    </a>

  </nav>

  <!-- ── 操作按钮 ── -->
  <div class="lnav-actions">
    <a href="/about" class="lnav-btn">
      <span>📝</span>
      <span data-i18n="btn.submit">投稿报道</span>
    </a>
    <a href="/about" class="lnav-btn">
      <span>🤝</span>
      <span data-i18n="btn.partner">合作入驻</span>
    </a>
  </div>

  <!-- ── 语言切换（真实 <a> 链接）── -->
  <div class="lnav-lang">
    <div class="lnav-lang-label">
      <span data-i18n="lang.label">语言</span>
    </div>
    <div class="lang-btns" role="group" aria-label="Language selection">
      {langList.map(([code]) => (
        <a
          href={langSwitchHref(code)}
          class:list={["lang-btn", { active: lang === code }]}
          data-lang-btn={code}
          aria-pressed={lang === code ? "true" : "false"}
          title={LANGUAGES[code]}
        >
          {shortLabel[code]}
        </a>
      ))}
    </div>
    <p style="font-size:10px;color:var(--fg-light);margin:4px 0 8px;text-align:center;">
      <span data-i18n="lang.auto">自动检测</span>
    </p>
  </div>

</aside>

<style>
.mobile-ham-btn {
  display: none;
  margin-left: auto;
  margin-right: 12px;
  padding: 6px;
  border: none;
  background: transparent;
  cursor: pointer;
  color: var(--fg-muted);
  border-radius: 4px;
  transition: background 0.12s;
}
.mobile-ham-btn:hover { background: var(--bg-elevated); }

.lnav-sub-link.active {
  color: var(--accent);
  background: var(--nav-active-bg);
}
.lnav-toggle[aria-expanded="true"] .arrow { transform: rotate(90deg); }
.arrow { transition: transform 0.2s; flex-shrink: 0; }
.lnav-toggle { justify-content: space-between; }

/* 语言按钮 — <a> 标签但外观与 <button> 一致 */
.lang-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 2px 7px;
  border-radius: 3px;
  font-size: 11px;
  font-weight: 600;
  border: 1px solid var(--border);
  color: var(--fg-muted);
  background: transparent;
  text-decoration: none;
  transition: color 0.12s, border-color 0.12s, background 0.12s;
  cursor: pointer;
}
.lang-btn:hover { color: var(--accent); border-color: var(--accent); }
.lang-btn.active {
  background: var(--accent);
  color: #fff;
  border-color: var(--accent);
}

@media (max-width: 768px) {
  .mobile-ham-btn { display: flex; }
}
</style>

<script>
function initToggles() {
  document.querySelectorAll<HTMLButtonElement>(".lnav-toggle").forEach(btn => {
    btn.addEventListener("click", () => {
      const key = btn.getAttribute("data-group");
      const sub = document.getElementById(`sub-${key}`);
      if (!sub) return;
      const open = sub.classList.toggle("open");
      btn.setAttribute("aria-expanded", open ? "true" : "false");
    });
  });
}

function initMobileNav() {
  const btn = document.getElementById("mobile-nav-btn");
  const nav = document.getElementById("lnav");
  if (!btn || !nav) return;
  btn.addEventListener("click", () => {
    const open = nav.classList.toggle("mobile-open");
    btn.setAttribute("aria-expanded", open ? "true" : "false");
  });
}

initToggles();
initMobileNav();
document.addEventListener("astro:after-swap", () => {
  initToggles();
  initMobileNav();
});
</script>

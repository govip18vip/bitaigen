---
// src/components/ScrollSubscribe.astro
// Scroll-triggered subscribe prompt — appears at 50% article depth
// Non-intrusive: small slide-up card, dismissable, won't show again for 7 days
import { getLang, useTranslations } from "@/i18n/ui";
const lang = getLang(Astro.url);
const t = useTranslations(lang);
---

<div id="scroll-subscribe" class="scroll-sub" aria-hidden="true">
  <button id="scroll-sub-close" class="scroll-sub-close" aria-label="Close">&times;</button>
  <div class="scroll-sub-inner">
    <div class="scroll-sub-icon">&#9993;</div>
    <div class="scroll-sub-text">
      <div class="scroll-sub-title">{t("subscribe.title")}</div>
      <div class="scroll-sub-desc">{t("subscribe.desc")}</div>
    </div>
    <form class="scroll-sub-form" data-subscribe-form data-placement="scroll_popup">
      <input type="email" name="email" required placeholder={t("subscribe.placeholder")} class="scroll-sub-input" />
      <button type="submit" class="scroll-sub-btn">{t("subscribe.btn")}</button>
    </form>
    <div id="scroll-sub-msg" class="scroll-sub-msg"></div>
  </div>
</div>

<style>
  .scroll-sub {
    position: fixed;
    bottom: -200px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 8000;
    width: calc(100% - 32px);
    max-width: 480px;
    background: var(--bg-card);
    border: 1px solid var(--accent);
    border-radius: 14px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    padding: 18px 20px;
    transition: bottom 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    opacity: 0;
  }
  .scroll-sub.visible {
    bottom: 76px;
    opacity: 1;
  }
  @media (min-width: 769px) {
    .scroll-sub.visible { bottom: 24px; }
  }
  .scroll-sub-close {
    position: absolute;
    top: 8px;
    right: 12px;
    background: none;
    border: none;
    font-size: 20px;
    color: var(--fg-muted);
    cursor: pointer;
    line-height: 1;
    padding: 4px;
  }
  .scroll-sub-inner {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .scroll-sub-icon {
    font-size: 24px;
  }
  .scroll-sub-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--fg);
  }
  .scroll-sub-desc {
    font-size: 12px;
    color: var(--fg-muted);
    line-height: 1.5;
  }
  .scroll-sub-form {
    display: flex;
    gap: 6px;
  }
  .scroll-sub-input {
    flex: 1;
    padding: 8px 12px;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 13px;
    background: var(--bg-elevated);
    color: var(--fg);
    min-width: 0;
  }
  .scroll-sub-input:focus {
    border-color: var(--accent);
    outline: none;
  }
  .scroll-sub-btn {
    padding: 8px 16px;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.15s;
  }
  .scroll-sub-btn:hover { opacity: 0.85; }
  .scroll-sub-msg {
    font-size: 12px;
    color: var(--accent-green);
    display: none;
  }
</style>

<script>
  function initScrollSubscribe() {
    const el = document.getElementById("scroll-subscribe");
    const closeBtn = document.getElementById("scroll-sub-close");
    const form = el?.querySelector("form");
    const msgEl = document.getElementById("scroll-sub-msg");
    if (!el) return;

    // Don't show if dismissed within 7 days
    const dismissed = localStorage.getItem("ba_sub_dismissed");
    if (dismissed && Date.now() - Number(dismissed) < 7 * 86400000) return;

    // Don't show if already subscribed
    if (localStorage.getItem("ba_subscribed")) return;

    let shown = false;
    let ticking = false;
    const article = document.getElementById("article");

    function check() {
      if (shown || !article) { ticking = false; return; }
      const rect = article.getBoundingClientRect();
      const scrolled = -rect.top + window.innerHeight;
      const pct = scrolled / article.offsetHeight;
      if (pct >= 0.5) {
        el.classList.add("visible");
        el.setAttribute("aria-hidden", "false");
        shown = true;
      }
      ticking = false;
    }

    window.addEventListener("scroll", () => {
      if (!ticking) { requestAnimationFrame(check); ticking = true; }
    }, { passive: true });

    closeBtn?.addEventListener("click", () => {
      el.classList.remove("visible");
      localStorage.setItem("ba_sub_dismissed", String(Date.now()));
    });

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = (form.querySelector("input[name=email]") as HTMLInputElement)?.value;
      if (!email) return;
      try {
        const resp = await fetch("/api/subscribe", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email }),
        });
        if (resp.ok) {
          if (msgEl) { msgEl.textContent = "✓ 订阅成功！"; msgEl.style.display = "block"; }
          form.style.display = "none";
          localStorage.setItem("ba_subscribed", "1");
          setTimeout(() => el.classList.remove("visible"), 3000);
        }
      } catch {}
    });
  }

  initScrollSubscribe();
  document.addEventListener("astro:after-swap", initScrollSubscribe);
</script>

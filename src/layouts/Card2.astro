---
// src/layouts/Card2.astro
//
// ✅ 此文件已废弃，功能已合并到 PostDetails.astro
// 保留空文件是为了避免其他可能引用此路径的地方报错
// 如果确认没有其他地方 import Card2.astro，可以直接删除此文件
//
// 删除方法：在项目根目录执行
//   rm src/layouts/Card2.astro
//
// 然后全局搜索确认没有地方 import Card2：
//   grep -r "Card2" src/

import type { CollectionEntry } from "astro:content";
import PostDetails from "./PostDetails.astro";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
};

const { post, posts } = Astro.props;
---

<PostDetails {post} {posts} />

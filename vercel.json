{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=30, s-maxage=60" },
        { "key": "Access-Control-Allow-Origin", "value": "https://bitaigen.com" }
      ]
    },
    {
      "source": "/rss.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "query", "key": "x_astro_path" }],
      "destination": "/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "query", "key": "hl" }],
      "destination": "/:path*",
      "permanent": true
    },
    {
      "source": "/tag/:slug",
      "destination": "/tags/:slug",
      "permanent": true
    },
    {
      "source": "/tag/:slug/:rest*",
      "destination": "/tags/:slug/:rest*",
      "permanent": true
    },
    {
      "source": "/category/:slug",
      "destination": "/tags/:slug",
      "permanent": true
    },
    {
      "source": "/category/:slug/:rest*",
      "destination": "/tags/:slug/:rest*",
      "permanent": true
    },
    {
      "source": "/page/1",
      "destination": "/archives",
      "permanent": true
    },
    {
      "source": "/page/:n",
      "destination": "/archives/page/:n",
      "permanent": true
    },
    {
      "source": "/news/page/:rest*",
      "destination": "/news",
      "permanent": true
    },
    {
      "source": "/en/archives/:slug*",
      "destination": "/archives/:slug*",
      "permanent": true
    },
    {
      "source": "/zh-tw/archives/:slug*",
      "destination": "/archives/:slug*",
      "permanent": true
    },
    {
      "source": "/es/archives/:slug*",
      "destination": "/archives/:slug*",
      "permanent": true
    },
    {
      "source": "/pt/archives/:slug*",
      "destination": "/archives/:slug*",
      "permanent": true
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap-index.xml",
      "permanent": true
    },
    {
      "source": "/feed",
      "destination": "/rss.xml",
      "permanent": true
    },
    {
      "source": "/feed.xml",
      "destination": "/rss.xml",
      "permanent": true
    },
    {
      "source": "/rss",
      "destination": "/rss.xml",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/article/:slug",
      "destination": "/archives/:slug"
    },
    {
      "source": "/articles/:path*",
      "destination": "/archives/:path*"
    }
  ]
}

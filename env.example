# ═══════════════════════════════════════════════
#  Bitaigen 环境变量示例
# ═══════════════════════════════════════════════
# 用法：
#   - 本地开发：复制为 .env.local，填入真实值
#   - Vercel 部署：在 Dashboard → Settings → Environment Variables 配置
#
# 命名约定：
#   - PUBLIC_*  前缀 = 会被打包进客户端，公开变量（非敏感）
#   - 其它      = 仅 SSR / build / 后端脚本可见（敏感）
#
# ⚠️ 任何以 .env 开头的文件（.env.local 等）都不应提交到 git。
# ⚠️ 一旦泄露，应立即在各服务控制台轮换 token。

# ═══════════════════════════════════════════════
#  Analytics & SEO（公开）
# ═══════════════════════════════════════════════
PUBLIC_GA_ID=                              # e.g. G-XXXXXXXXXX
PUBLIC_GOOGLE_SITE_VERIFICATION=           # Search Console meta 值
PUBLIC_BING_SITE_VERIFICATION=
PUBLIC_YANDEX_SITE_VERIFICATION=

# ═══════════════════════════════════════════════
#  Sanity CMS（项目ID / 数据集为公开信息）
# ═══════════════════════════════════════════════
PUBLIC_SANITY_PROJECT_ID=jnjofxo7
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2025-04-07

# ⚠️ 敏感：只在 SSR 构建阶段使用，永远不要标 PUBLIC_
SANITY_READ_TOKEN=                         # Sanity Viewer token（只读）
SANITY_WRITE_TOKEN=                        # ⚠️ 写权限 token，仅 pipeline/ 脚本使用

# ═══════════════════════════════════════════════
#  Ghost CMS（可选）
# ═══════════════════════════════════════════════
GHOST_URL=                                 # e.g. https://your-ghost.ghost.io
GHOST_CONTENT_KEY=                         # Content API key（只读，相对安全）
# GHOST_ADMIN_KEY=                         # ⚠️ Admin key，仅后端脚本使用

# ═══════════════════════════════════════════════
#  Email Subscription（Resend）—— 敏感
# ═══════════════════════════════════════════════
RESEND_API_KEY=                            # ⚠️ 服务端密钥
RESEND_AUDIENCE_ID=                        # 订阅者列表 ID
RESEND_FROM_EMAIL=                         # 已验证域名发件地址

# ═══════════════════════════════════════════════
#  Rate limiting（可选，推荐生产环境配置）
# ═══════════════════════════════════════════════
# 使用 Upstash Redis 做持久化速率限制，避免 serverless 重启丢状态
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ═══════════════════════════════════════════════
#  Content Pipeline（仅 Python 自动化脚本使用）
# ═══════════════════════════════════════════════
# LILYS_ACCESS_TOKEN=
# LILYS_REFRESH_TOKEN=
# BIYIJIA_API_KEY=
